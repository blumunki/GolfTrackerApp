@using GolfTrackerApp.Mobile.Services.Api
@using GolfTrackerApp.Mobile.Models
@using GolfTrackerApp.Mobile.Services
@inject IDashboardApiService DashboardService
@inject IRoundApiService RoundApiService
@inject IPlayerReportApiService PlayerReportApiService
@inject IInsightsApiService InsightsService
@inject NavigationManager Navigation

<MudContainer MaxWidth="MaxWidth.Large" Class="pa-4" Style="padding-bottom: 80px;">
    @if (loadingDashboard)
    {
        <MudStack AlignItems="AlignItems.Center" Spacing="4" Style="margin-top: 100px;">
            <MudProgressCircular Color="Color.Primary" Size="Size.Large" Indeterminate="true" />
            <MudText Typo="Typo.h6" Color="Color.Primary">Loading your golf dashboard...</MudText>
        </MudStack>
    }
    else if (!string.IsNullOrEmpty(errorMessage))
    {
        <MudStack AlignItems="AlignItems.Center" Spacing="4" Style="margin-top: 100px;">
            <MudIcon Icon="@Icons.Material.Filled.ErrorOutline" Size="Size.Large" Color="Color.Error" />
            <MudText Typo="Typo.h5" Color="Color.Error">Unable to Connect to API</MudText>
            <MudText Typo="Typo.body1" Align="Align.Center" Color="Color.Default">
                @errorMessage
            </MudText>
            <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="LoadDashboardData">
                Try Again
            </MudButton>
        </MudStack>
    }
    else if (dashboardStats?.TotalRounds == 0)
    {
        <MudStack AlignItems="AlignItems.Center" Spacing="4" Style="margin-top: 100px;">
            <MudIcon Icon="@Icons.Material.Filled.GolfCourse" Size="Size.Large" Color="Color.Primary" />
            <MudText Typo="Typo.h5" Color="Color.Primary">Welcome to Golf Tracker!</MudText>
            <MudText Typo="Typo.body1" Align="Align.Center" Color="Color.Default">
                You haven't recorded any rounds yet. Start tracking your golf progress today!
            </MudText>
        </MudStack>
    }
    else if (dashboardStats != null)
    {
        <!-- Hero Stats -->
        <HeroStatsWidget Stats="dashboardStats" />

        <!-- Performance Chart -->
        <MudCard Elevation="2" Class="mb-3">
            <MudCardHeader>
                <CardHeaderContent>
                    <MudText Typo="Typo.h6">📈 Performance Trend</MudText>
                </CardHeaderContent>
            </MudCardHeader>
            <MudCardContent>
                @if (performanceSeries?.Any() == true)
                {
                    <MudChart ChartType="ChartType.Line" 
                             ChartSeries="@performanceSeries" 
                             XAxisLabels="@performanceXAxisLabels" 
                             Width="100%" 
                             Height="180px"
                             ChartOptions="@chartOptions">
                    </MudChart>
                }
                else
                {
                    <div class="text-center pa-4">
                        <MudIcon Icon="@Icons.Material.Filled.TrendingUp" Size="Size.Large" Color="Color.Secondary" />
                        <MudText Typo="Typo.body2" Color="Color.Secondary">Play a few rounds to see your trends.</MudText>
                    </div>
                }
            </MudCardContent>
        </MudCard>

        <!-- Course Diary -->
        <CourseDiaryWidget Courses="courseHistory" />

        <!-- Par Performance -->
        <ParPerformanceWidget PerformanceData="performanceByPar" />

        <!-- Scoring Breakdown -->
        <ScoringBreakdownWidget Distribution="scoringDistribution" />

        <!-- AI Insights -->
        @if (dashboardStats?.TotalRounds > 0)
        {
            <AiInsightsWidget Insight="aiInsight" Loading="aiLoading" OnRefresh="RefreshAiInsights" />
        }

        <!-- Recent Rounds -->
        <MudCard Elevation="2" Class="mb-3">
            <MudCardHeader>
                <CardHeaderContent>
                    <MudText Typo="Typo.h6">🏌️ Recent Rounds</MudText>
                </CardHeaderContent>
                <CardHeaderActions>
                    <MudIconButton Icon="@Icons.Material.Filled.List" 
                                  Color="Color.Primary"
                                  OnClick="@NavigateToRounds" />
                </CardHeaderActions>
            </MudCardHeader>
            <MudCardContent Class="pa-0">
                @if (recentRounds?.Any() == true)
                {
                    <MudList T="object" Dense="true">
                        @foreach (var round in recentRounds)
                        {
                            <MudListItem T="object" OnClick="@(() => NavigateToRoundDetail(round.Id))">
                                <div class="d-flex justify-space-between align-center flex-grow-1">
                                    <div class="d-flex flex-column" style="min-width: 0; flex: 1;">
                                        <MudText Typo="Typo.body2" Style="font-weight: 600; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">
                                            @if (!string.IsNullOrEmpty(round.GolfClubName))
                                            {
                                                @round.GolfClubName<text> – </text>@round.GolfCourseName
                                            }
                                            else
                                            {
                                                @round.GolfCourseName
                                            }
                                        </MudText>
                                        <MudText Typo="Typo.caption" Color="Color.Secondary">
                                            @($"{round.DatePlayed:ddd, dd MMM yyyy}")
                                        </MudText>
                                    </div>
                                    <div class="text-right" style="margin-left: 12px;">
                                        <MudText Typo="Typo.body1" Color="Color.Primary" Style="font-weight: 700;">
                                            @round.TotalScore
                                        </MudText>
                                        <MudText Typo="Typo.caption" Color="@(round.ToPar < 0 ? Color.Success : round.ToPar > 0 ? Color.Warning : Color.Info)">
                                            @(round.ToPar >= 0 ? "+" : "")@round.ToPar
                                        </MudText>
                                    </div>
                                </div>
                            </MudListItem>
                        }
                    </MudList>
                }
                else
                {
                    <div class="text-center pa-4">
                        <MudText Typo="Typo.body2" Color="Color.Secondary">
                            No rounds recorded yet.
                        </MudText>
                    </div>
                }
            </MudCardContent>
        </MudCard>

        <!-- Quick Access: Societies -->
        <MudCard Elevation="2" Class="mb-4" @onclick="@(() => Navigation.NavigateTo("/societies"))" Style="cursor:pointer;">
            <MudCardContent Class="d-flex align-center gap-3 pa-3">
                <MudIcon Icon="@Icons.Material.Filled.Groups" Color="Color.Primary" Size="Size.Large" />
                <div>
                    <MudText Typo="Typo.subtitle1" Style="font-weight: 600;">Societies</MudText>
                    <MudText Typo="Typo.caption" Color="Color.Secondary">Join or create golf societies</MudText>
                </div>
                <MudSpacer />
                <MudIcon Icon="@Icons.Material.Filled.ChevronRight" Color="Color.Secondary" />
            </MudCardContent>
        </MudCard>

        <!-- Playing Partners -->
        <MudCard Elevation="2">
            <MudCardHeader>
                <CardHeaderContent>
                    <MudText Typo="Typo.h6">👥 Playing Partners</MudText>
                </CardHeaderContent>
                <CardHeaderActions>
                    <MudIconButton Icon="@Icons.Material.Filled.People" 
                                  Color="Color.Primary"
                                  OnClick="@NavigateToPlayers" />
                </CardHeaderActions>
            </MudCardHeader>
            <MudCardContent Class="pa-0">
                @if (partnerSummary?.Any() == true)
                {
                    <MudList T="object" Dense="true">
                        @foreach (var partner in partnerSummary)
                        {
                            <MudListItem T="object" OnClick="@(() => NavigateToPlayerReport(partner.PartnerId))">
                                <div class="d-flex justify-space-between align-center flex-grow-1">
                                    <div class="d-flex flex-column">
                                        <MudText Typo="Typo.body2" Class="fw-semibold">@partner.PartnerName</MudText>
                                        <MudText Typo="Typo.caption" Color="Color.Secondary">
                                            Last played: @($"{partner.LastPlayedDate:dd MMM yyyy}")
                                        </MudText>
                                    </div>
                                    <div class="text-right">
                                        <MudText Typo="Typo.body2" Color="@(partner.UserWins > partner.PartnerWins ? Color.Success : partner.UserWins < partner.PartnerWins ? Color.Warning : Color.Info)">
                                            <strong>@partner.UserWins-@partner.PartnerWins-@partner.Ties</strong>
                                        </MudText>
                                        <MudText Typo="Typo.caption">
                                            @(partner.UserWins > partner.PartnerWins ? "You lead!" : 
                                              partner.UserWins < partner.PartnerWins ? "You trail" : "It's tied!")
                                        </MudText>
                                    </div>
                                </div>
                            </MudListItem>
                        }
                    </MudList>
                }
                else
                {
                    <div class="text-center pa-4">
                        <MudText Typo="Typo.body2" Color="Color.Secondary">
                            Play with friends to track your rivalry!
                        </MudText>
                    </div>
                }
            </MudCardContent>
        </MudCard>
        

    }
</MudContainer>

@code {
    private bool loadingDashboard = true;
    private string? errorMessage = null;
    private DashboardStats? dashboardStats = null;
    
    // Chart data
    private List<ChartSeries>? performanceSeries;
    private string[]? performanceXAxisLabels;
    private ChartOptions chartOptions = new ChartOptions();
    
    // Recent rounds and partners
    private List<RecentRound>? recentRounds;
    private List<PartnerSummary>? partnerSummary;
    private List<CourseHistoryItem>? courseHistory;
    private ScoringDistributionData? scoringDistribution;
    private PerformanceByParData? performanceByPar;
    private AiInsightResult? aiInsight;
    private bool aiLoading;

    protected override async Task OnInitializedAsync()
    {
        await LoadDashboardData();
        await LoadAdditionalData();
        _ = LoadAiInsights();
    }

    private async Task LoadDashboardData()
    {
        loadingDashboard = true;
        errorMessage = null;
        StateHasChanged();

        try
        {
            dashboardStats = await DashboardService.GetDashboardStatsAsync();
        }
        catch (Exception ex)
        {
            errorMessage = $"Failed to load dashboard: {ex.Message}";
        }
        finally
        {
            loadingDashboard = false;
            StateHasChanged();
        }
    }
    
    private async Task LoadAdditionalData()
    {
        try
        {
            // Load recent rounds with club name
            var allRounds = await RoundApiService.GetAllRoundsAsync();
            recentRounds = allRounds?
                .OrderByDescending(r => r.DatePlayed)
                .Take(5)
                .Select(r => new RecentRound
                {
                    Id = r.RoundId,
                    GolfCourseName = r.CourseName ?? "Unknown Course",
                    GolfClubName = r.ClubName ?? "",
                    DatePlayed = r.DatePlayed,
                    TotalScore = r.TotalScore,
                    ToPar = r.TotalScore - r.TotalPar
                }).ToList();
            
            // Build performance chart from recent rounds (last 10)
            var chartRounds = allRounds?
                .OrderByDescending(r => r.DatePlayed)
                .Take(10)
                .OrderBy(r => r.DatePlayed)
                .ToList();

            if (chartRounds?.Any() == true)
            {
                performanceSeries = new List<ChartSeries>
                {
                    new ChartSeries
                    {
                        Name = "Score vs Par",
                        Data = chartRounds.Select(r => (double)(r.TotalScore - r.TotalPar)).ToArray()
                    }
                };
                performanceXAxisLabels = chartRounds.Select(r => r.DatePlayed.ToString("dd/MM")).ToArray();
            }
            
            // Load playing partners, course history, scoring distribution, par performance in parallel
            var partnersTask = DashboardService.GetPlayingPartnersAsync(5);
            var courseHistoryTask = DashboardService.GetCourseHistoryAsync(6);
            var scoringDistTask = DashboardService.GetScoringDistributionDataAsync();
            var parPerfTask = DashboardService.GetPerformanceByParAsync();

            await Task.WhenAll(partnersTask, courseHistoryTask, scoringDistTask, parPerfTask);

            var partners = partnersTask.Result;
            if (partners?.Any() == true)
            {
                partnerSummary = partners.Select(p => new PartnerSummary
                {
                    PartnerId = p.PartnerId,
                    PartnerName = p.PartnerName,
                    LastPlayedDate = p.LastPlayedDate,
                    UserWins = p.UserWins,
                    PartnerWins = p.PartnerWins,
                    Ties = p.Ties
                }).ToList();
            }
            else
            {
                partnerSummary = new List<PartnerSummary>();
            }

            courseHistory = courseHistoryTask.Result;
            scoringDistribution = scoringDistTask.Result;
            performanceByPar = parPerfTask.Result;
            
            StateHasChanged();
        }
        catch (Exception)
        {
        }
    }
    
    // Simple data classes for display
    private class RecentRound
    {
        public int Id { get; set; }
        public string GolfCourseName { get; set; } = "";
        public string GolfClubName { get; set; } = "";
        public DateTime DatePlayed { get; set; }
        public int TotalScore { get; set; }
        public int ToPar { get; set; }
    }
    
    private class PartnerSummary
    {
        public int PartnerId { get; set; }
        public string PartnerName { get; set; } = "";
        public DateTime LastPlayedDate { get; set; }
        public int UserWins { get; set; }
        public int PartnerWins { get; set; }
        public int Ties { get; set; }
    }
    
    // Navigation methods
    private void NavigateToRounds()
    {
        Navigation.NavigateTo("/rounds");
    }
    
    private void NavigateToPlayers()
    {
        Navigation.NavigateTo("/players");
    }
    
    private void NavigateToRoundDetail(int roundId)
    {
        Navigation.NavigateTo($"/rounds/{roundId}");
    }
    
    private void NavigateToPlayerReport(int playerId)
    {
        Navigation.NavigateTo($"/players/{playerId}/report");
    }

    private async Task LoadAiInsights()
    {
        if (dashboardStats == null || dashboardStats.TotalRounds == 0) return;

        aiLoading = true;
        StateHasChanged();
        try
        {
            aiInsight = await InsightsService.GetDashboardInsightsAsync();
        }
        catch
        {
            aiInsight = new AiInsightResult
            {
                Success = false,
                ErrorMessage = "Could not load AI insights."
            };
        }
        finally
        {
            aiLoading = false;
            StateHasChanged();
        }
    }

    private async Task RefreshAiInsights()
    {
        await LoadAiInsights();
    }
}
