@using GolfTrackerApp.Web.Models
@using GolfTrackerApp.Web.Services
@implements IAsyncDisposable
@inject INotificationService NotificationService
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject NavigationManager NavigationManager

<MudBadge Content="@_unreadCount" Color="Color.Error" Overlap="true" Visible="@(_unreadCount > 0)">
    <MudIconButton Icon="@Icons.Material.Filled.Notifications" 
                   Color="Color.Inherit" 
                   OnClick="@ToggleMenu"
                   aria-label="Notifications" />
</MudBadge>

<MudPopover Open="@_isOpen" 
            AnchorOrigin="Origin.BottomRight" 
            TransformOrigin="Origin.TopRight"
            Paper="true"
            Class="notification-popover">
    <MudPaper Style="width: 320px; max-height: 400px; overflow-y: auto;">
        <MudStack Class="pa-3" Spacing="2">
            <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
                <MudText Typo="Typo.h6">Notifications</MudText>
                @if (_unreadCount > 0)
                {
                    <MudButton Size="Size.Small" 
                               Variant="Variant.Text" 
                               Color="Color.Primary" 
                               OnClick="@MarkAllAsRead">
                        Mark all read
                    </MudButton>
                }
            </MudStack>
            
            <MudDivider />
            
            @if (_notifications.Count == 0)
            {
                <MudText Typo="Typo.body2" Color="Color.Secondary" Class="text-center py-4">
                    No notifications
                </MudText>
            }
            else
            {
                @foreach (var notification in _notifications)
                {
                    <MudPaper Class="@GetNotificationClass(notification)" 
                              Elevation="0"
                              @onclick="() => HandleNotificationClick(notification)">
                        <MudStack Spacing="1">
                            <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Start">
                                <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Center">
                                    <MudIcon Icon="@GetNotificationIcon(notification.Type)" 
                                             Size="Size.Small" 
                                             Color="@GetNotificationColor(notification.Type)" />
                                    <MudText Typo="Typo.body2" Style="font-weight: 600;">
                                        @notification.Title
                                    </MudText>
                                </MudStack>
                                @if (!notification.IsRead)
                                {
                                    <MudIcon Icon="@Icons.Material.Filled.Circle" 
                                             Size="Size.Small" 
                                             Color="Color.Primary" 
                                             Style="font-size: 8px;" />
                                }
                            </MudStack>
                            <MudText Typo="Typo.caption" Color="Color.Secondary">
                                @notification.Message
                            </MudText>
                            <MudText Typo="Typo.caption" Color="Color.Tertiary">
                                @FormatTimeAgo(notification.CreatedAt)
                            </MudText>
                        </MudStack>
                    </MudPaper>
                }
            }
        </MudStack>
    </MudPaper>
</MudPopover>

@code {
    private bool _isOpen;
    private int _unreadCount;
    private List<Notification> _notifications = new();
    private string? _userId;
    private CancellationTokenSource? _cts;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        
        if (user.Identity?.IsAuthenticated == true)
        {
            _userId = user.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
            if (_userId != null)
            {
                await LoadNotificationsAsync();
                
                // Start background refresh task
                _cts = new CancellationTokenSource();
                _ = RefreshNotificationsPeriodicallyAsync(_cts.Token);
            }
        }
    }

    private async Task RefreshNotificationsPeriodicallyAsync(CancellationToken cancellationToken)
    {
        using var timer = new PeriodicTimer(TimeSpan.FromSeconds(30));
        
        try
        {
            while (await timer.WaitForNextTickAsync(cancellationToken))
            {
                await InvokeAsync(async () =>
                {
                    await LoadNotificationsAsync();
                    StateHasChanged();
                });
            }
        }
        catch (OperationCanceledException)
        {
            // Normal cancellation during dispose, ignore
        }
    }

    private async Task LoadNotificationsAsync()
    {
        if (_userId == null) return;
        
        try
        {
            _notifications = await NotificationService.GetNotificationsAsync(_userId, 10);
            _unreadCount = await NotificationService.GetUnreadCountAsync(_userId);
        }
        catch (ObjectDisposedException)
        {
            // Service disposed, ignore
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading notifications: {ex.Message}");
        }
    }

    private void ToggleMenu()
    {
        _isOpen = !_isOpen;
    }

    private async Task HandleNotificationClick(Notification notification)
    {
        if (_userId == null) return;
        
        if (!notification.IsRead)
        {
            await NotificationService.MarkAsReadAsync(notification.Id, _userId);
            notification.IsRead = true;
            _unreadCount = Math.Max(0, _unreadCount - 1);
        }
        
        _isOpen = false;
        
        if (!string.IsNullOrEmpty(notification.ActionUrl))
        {
            NavigationManager.NavigateTo(notification.ActionUrl);
        }
    }

    private async Task MarkAllAsRead()
    {
        if (_userId == null) return;
        
        await NotificationService.MarkAllAsReadAsync(_userId);
        foreach (var notification in _notifications)
        {
            notification.IsRead = true;
        }
        _unreadCount = 0;
    }

    private string GetNotificationClass(Notification notification)
    {
        var baseClass = "pa-2 rounded cursor-pointer notification-item";
        return notification.IsRead ? baseClass : $"{baseClass} unread-notification";
    }

    private string GetNotificationIcon(NotificationType type) => type switch
    {
        NotificationType.ConnectionRequest => Icons.Material.Filled.PersonAdd,
        NotificationType.ConnectionAccepted => Icons.Material.Filled.CheckCircle,
        NotificationType.ConnectionDeclined => Icons.Material.Filled.Cancel,
        NotificationType.MergeRequest => Icons.Material.Filled.MergeType,
        NotificationType.MergeCompleted => Icons.Material.Filled.Done,
        NotificationType.MergeDeclined => Icons.Material.Filled.Block,
        _ => Icons.Material.Filled.Notifications
    };

    private Color GetNotificationColor(NotificationType type) => type switch
    {
        NotificationType.ConnectionRequest => Color.Primary,
        NotificationType.ConnectionAccepted => Color.Success,
        NotificationType.ConnectionDeclined => Color.Error,
        NotificationType.MergeRequest => Color.Info,
        NotificationType.MergeCompleted => Color.Success,
        NotificationType.MergeDeclined => Color.Error,
        _ => Color.Default
    };

    private string FormatTimeAgo(DateTime dateTime)
    {
        var timeSpan = DateTime.UtcNow - dateTime;
        
        if (timeSpan.TotalMinutes < 1)
            return "Just now";
        if (timeSpan.TotalMinutes < 60)
            return $"{(int)timeSpan.TotalMinutes}m ago";
        if (timeSpan.TotalHours < 24)
            return $"{(int)timeSpan.TotalHours}h ago";
        if (timeSpan.TotalDays < 7)
            return $"{(int)timeSpan.TotalDays}d ago";
        
        return dateTime.ToLocalTime().ToString("MMM d");
    }

    public async ValueTask DisposeAsync()
    {
        if (_cts != null)
        {
            await _cts.CancelAsync();
            _cts.Dispose();
        }
    }
}
