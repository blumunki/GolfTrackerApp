@page "/handicaps"
@attribute [Authorize]
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject IPlayerService PlayerService

@using GolfTrackerApp.Core.Services
@using Microsoft.AspNetCore.Authorization
@using System.Security.Claims

@rendermode InteractiveServer

<PageTitle>My Handicap</PageTitle>

<MudText Typo="Typo.h4" Class="mb-4">My Handicap</MudText>

@if (_loading)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
}
else if (_playerId is null)
{
    <MudAlert Severity="Severity.Info">
        Your account is not linked to a player profile yet, so there are no handicaps to show.
    </MudAlert>
}
else
{
    <HandicapPanel PlayerId="_playerId.Value" />
}

@code {
    private bool _loading = true;
    private int? _playerId;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var userId = authState.User.FindFirstValue(ClaimTypes.NameIdentifier);
        if (userId is not null)
        {
            var player = await PlayerService.GetPlayerByApplicationUserIdAsync(userId);
            _playerId = player?.PlayerId;
        }
        _loading = false;
    }
}
