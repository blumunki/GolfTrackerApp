@page "/players/{PlayerId:int}/report"
@attribute [Authorize]
@rendermode InteractiveServer

@inject IPlayerService PlayerService
@inject IReportService ReportService
@inject IGolfCourseService CourseService
@inject NavigationManager NavigationManager
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject IAiInsightService AiInsightService
@inject IConfiguration Configuration

@using System.Globalization
@using GolfTrackerApp.Web.Models
@using Microsoft.AspNetCore.Authorization
@using System.Security.Claims
@using GolfTrackerApp.Web.Services
@using GolfTrackerApp.Web.Components.Shared

<PageTitle>Player Performance Report</PageTitle>

@if (_isInitialLoading)
{
    <div class="report-loading">
        <MudProgressCircular Indeterminate="true" Size="Size.Large" Color="Color.Primary" />
        <MudText Typo="Typo.body1" Class="mt-3" Color="Color.Secondary">Loading performance data...</MudText>
    </div>
}
else
{
    <!-- Compact Header -->
    <div class="d-flex align-center gap-3 mb-2">
        <MudBreadcrumbs Items="_breadcrumbs" Class="pa-0" Style="padding:0;"></MudBreadcrumbs>
    </div>
    <div class="d-flex align-center gap-3 mb-3">
        <MudAvatar Color="Color.Primary" Size="Size.Medium">
            @(_viewModel.Player != null ? $"{(_viewModel.Player.FirstName?.Length > 0 ? _viewModel.Player.FirstName[..1] : "")}{(_viewModel.Player.LastName?.Length > 0 ? _viewModel.Player.LastName[..1] : "")}" : "?")
        </MudAvatar>
        <div>
            <MudText Typo="Typo.h5" Style="font-weight: 700; line-height: 1.2;">@_viewModel.Player?.FirstName @_viewModel.Player?.LastName</MudText>
            <MudText Typo="Typo.caption" Color="Color.Secondary">Performance Analytics</MudText>
        </div>
    </div>

    <!-- Summary Stat Strip (compact) -->
    @if (_viewModel.PerformanceData?.Any() == true)
    {
        <div class="d-flex flex-wrap gap-3 mb-2">
            @{
                var avgToPar = _viewModel.PerformanceData.Average(d => (double)d.ScoreVsPar);
                var avgToParClass = avgToPar < 0 ? "stat-under-par" : avgToPar > 0 ? "stat-over-par" : "";
            }
            <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined">🏌️ @_viewModel.PerformanceData.Count Rounds</MudChip>
            <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined">🏆 Best: @_viewModel.PerformanceData.Min(d => d.TotalScore)</MudChip>
            <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined">📊 Avg: @_viewModel.PerformanceData.Average(d => d.TotalScore).ToString("F1")</MudChip>
            <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined">⛳ <span class="@avgToParClass">@(avgToPar >= 0 ? "+" : "")@avgToPar.ToString("F1")</span> vs Par</MudChip>
            <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined">📅 @_viewModel.PerformanceData.Max(d => d.Date).ToString("dd MMM")</MudChip>
        </div>
    }

    @* ── AI Analysis Panel (expandable, on-demand) ── *@
    @if (_aiInsightEnabled && !string.IsNullOrEmpty(_currentUserId) && _viewModel.PerformanceData?.Any() == true)
    {
        <MudExpansionPanels Class="mb-2" Elevation="0">
            <MudExpansionPanel @bind-Expanded="_aiPanelExpanded" Class="gp-card" Dense="true">
                <TitleContent>
                    <div class="d-flex align-center gap-2">
                        <MudIcon Icon="@Icons.Material.Filled.AutoAwesome" Size="Size.Small" Color="Color.Warning" />
                        <MudText Typo="Typo.subtitle2">AI Analysis</MudText>
                    </div>
                </TitleContent>
                <ChildContent>
                    @if (_aiLoading)
                    {
                        <MudProgressLinear Indeterminate="true" Color="Color.Primary" Class="mb-2" />
                        <MudText Typo="Typo.caption" Color="Color.Secondary">Analysing performance data...</MudText>
                    }
                    else if (_aiInsight?.Success == true)
                    {
                        <MudText Typo="Typo.body2" Style="white-space: pre-line;">@_aiInsight.Content</MudText>
                        @if (!string.IsNullOrEmpty(_aiInsight.StaleMessage))
                        {
                            <MudAlert Severity="Severity.Info" Dense="true" Class="mt-2">@_aiInsight.StaleMessage</MudAlert>
                        }
                        <MudText Typo="Typo.caption" Color="Color.Tertiary" Class="mt-2" Style="font-size: 0.7rem;">Powered by @_aiInsight.ProviderUsed • <MudLink OnClick="LoadPlayerReportInsights" Typo="Typo.caption">Refresh</MudLink></MudText>
                    }
                    else if (_aiInsight != null)
                    {
                        <MudAlert Severity="Severity.Warning" Dense="true">@(_aiInsight.ErrorMessage ?? "Could not load AI insights.")</MudAlert>
                    }
                </ChildContent>
            </MudExpansionPanel>
        </MudExpansionPanels>
    }
    <!-- Filters & Comparison Controls -->
    <div class="report-controls mb-2">
        <MudExpansionPanels Elevation="0" Class="report-filter-panel">
            <MudExpansionPanel Text="Filters & Comparison" Expanded="false" Class="report-filter-expansion" Dense="true">
                <MudGrid Spacing="2">
                    <MudItem xs="12" sm="6" md="3">
                        <MudSelect T="int?" Label="Course" @bind-Value="SelectedCourseId" Clearable="true" Disabled="_isFilterLoading" Variant="Variant.Outlined" Dense="true">
                            @foreach (var course in _viewModel.FilterCourses.OrderBy(c => c.GolfClub!.Name).ThenBy(c => c.Name))
                            {
                                <MudSelectItem T="int?" Value="@course.GolfCourseId">@($"{course.GolfClub!.Name} - {course.Name}")</MudSelectItem>
                            }
                        </MudSelect>
                    </MudItem>
                    <MudItem xs="6" sm="3" md="2">
                        <MudSelect T="int?" Label="Holes" @bind-Value="SelectedHolesPlayed" Clearable="true" Disabled="_isFilterLoading" Variant="Variant.Outlined" Dense="true">
                            <MudSelectItem T="int?" Value="9">9 Holes</MudSelectItem>
                            <MudSelectItem T="int?" Value="18">18 Holes</MudSelectItem>
                        </MudSelect>
                    </MudItem>
                    <MudItem xs="6" sm="3" md="2">
                        <MudSelect T="RoundTypeOption?" Label="Type" @bind-Value="SelectedRoundType" Clearable="true" Disabled="_isFilterLoading" Variant="Variant.Outlined" Dense="true">
                            <MudSelectItem T="RoundTypeOption?" Value="@RoundTypeOption.Friendly">Friendly</MudSelectItem>
                            <MudSelectItem T="RoundTypeOption?" Value="@RoundTypeOption.Competitive">Competitive</MudSelectItem>
                        </MudSelect>
                    </MudItem>
                    <MudItem xs="6" sm="3" md="2">
                        <MudDatePicker Label="From" @bind-Date="StartDate" Clearable="true" Culture="_ukCulture" DateFormat="dd/MM/yyyy" Disabled="_isFilterLoading" Variant="Variant.Outlined" />
                    </MudItem>
                    <MudItem xs="6" sm="3" md="2">
                        <MudDatePicker Label="To" @bind-Date="EndDate" Clearable="true" Culture="_ukCulture" DateFormat="dd/MM/yyyy" Disabled="_isFilterLoading" Variant="Variant.Outlined" />
                    </MudItem>
                    <MudItem xs="12" md="3">
                        <MudSwitch @bind-Value="ShowScoreVsPar" Label="Score vs Par" Color="Color.Primary" Disabled="_isFilterLoading" />
                    </MudItem>
                    
                    <!-- Player Comparison Selector -->
                    <MudItem xs="12">
                        <MudDivider Class="my-1" />
                        <MudText Typo="Typo.subtitle2" Color="Color.Secondary" Class="mb-2">Compare with other players</MudText>
                        <div class="d-flex flex-wrap gap-2 align-center">
                            @foreach (var cp in _comparisonPlayers)
                            {
                                <MudChip T="string" Color="Color.Primary" OnClose="() => RemoveComparisonPlayer(cp.PlayerId)">
                                    @cp.FirstName @cp.LastName
                                </MudChip>
                            }
                            @if (_availablePlayers.Any(p => !_comparisonPlayerIds.Contains(p.PlayerId) && p.PlayerId != PlayerId))
                            {
                                <MudSelect T="int?" Label="Add player..." @bind-Value="AddPlayerSelection" Clearable="true" 
                                           Variant="Variant.Outlined" Dense="true" Style="max-width: 250px;"
                                           Disabled="_isFilterLoading">
                                    @foreach (var player in _availablePlayers.Where(p => !_comparisonPlayerIds.Contains(p.PlayerId) && p.PlayerId != PlayerId).OrderBy(p => p.FirstName))
                                    {
                                        <MudSelectItem T="int?" Value="@player.PlayerId">@player.FirstName @player.LastName</MudSelectItem>
                                    }
                                </MudSelect>
                            }
                        </div>
                    </MudItem>
                </MudGrid>
            </MudExpansionPanel>
        </MudExpansionPanels>
    </div>

    @if (_isFilterLoading)
    {
        <MudProgressLinear Indeterminate="true" Class="my-4" Color="Color.Primary" />
    }
    else if (_viewModel.PerformanceData?.Any() == true)
    {
        <!-- Performance Over Time Chart -->
        <div class="gp-card report-chart-section">
            <div class="report-chart-header">
                <MudText Typo="Typo.h6">📈 Performance Trend</MudText>
            </div>
            <div class="golf-chart-container report-chart-tall">
                <MudChart ChartType="ChartType.Line" 
                          ChartSeries="@_series" 
                          XAxisLabels="@_xAxisLabels" 
                          ChartOptions="@_lineChartOptions"
                          AxisChartOptions="@_lineAxisChartOptions"
                          Width="100%" 
                          Height="100%"></MudChart>
            </div>
            @if (!_comparisonPlayers.Any())
            {
                <MudText Typo="Typo.caption" Color="Color.Secondary" Class="pa-3">
                    💡 Click on "Filters & Comparison" above to add other players for multi-line comparison
                </MudText>
            }
        </div>

        <!-- Analytics Row: Scoring Distribution + Par Performance -->
        <MudGrid Spacing="3" Class="mt-4">
            <!-- Scoring Distribution -->
            <MudItem xs="12" md="6">
                <div class="gp-card report-analytics-card">
                    <MudText Typo="Typo.h6" Class="pa-4 pb-0">🎯 Scoring Distribution</MudText>
                    @if (_scoringDistribution?.TotalHoles > 0)
                    {
                        <div class="report-scoring-visual pa-4">
                            <div class="report-scoring-bars">
                                @{
                                    var scoringItems = new (string Label, int Count, double Pct, string Color)[]
                                    {
                                        ("Eagle", _scoringDistribution.EagleCount, _scoringDistribution.EaglePercentage, "#FFD700"),
                                        ("Birdie", _scoringDistribution.BirdieCount, _scoringDistribution.BirdiePercentage, "#E53935"),
                                        ("Par", _scoringDistribution.ParCount, _scoringDistribution.ParPercentage, "#43A047"),
                                        ("Bogey", _scoringDistribution.BogeyCount, _scoringDistribution.BogeyPercentage, "#1E88E5"),
                                        ("Double", _scoringDistribution.DoubleBogeyCount, _scoringDistribution.DoubleBogeyPercentage, "#8E24AA"),
                                        ("Triple+", _scoringDistribution.TripleBogeyOrWorseCount, _scoringDistribution.TripleBogeyOrWorsePercentage, "#546E7A")
                                    };
                                }
                                @foreach (var item in scoringItems.Where(i => i.Count > 0))
                                {
                                    <div class="report-scoring-bar-row">
                                        <span class="report-scoring-bar-label">@item.Label</span>
                                        <div class="report-scoring-bar-track">
                                            <div class="report-scoring-bar-fill" style="width: @item.Pct.ToString("F1", CultureInfo.InvariantCulture)%; background: @item.Color;"></div>
                                        </div>
                                        <span class="report-scoring-bar-value">@item.Count (@item.Pct.ToString("F1")%)</span>
                                    </div>
                                }
                            </div>
                            <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mt-2">Based on @_scoringDistribution.TotalHoles holes</MudText>
                        </div>
                    }
                    else
                    {
                        <div class="report-analytics-empty pa-4">
                            <MudAlert Severity="Severity.Info" Dense="true">No scoring data for selected filters.</MudAlert>
                        </div>
                    }
                </div>
            </MudItem>

            <!-- Performance by Par -->
            <MudItem xs="12" md="6">
                <div class="gp-card report-analytics-card">
                    <MudText Typo="Typo.h6" Class="pa-4 pb-0">⛳ Performance by Par</MudText>
                    @if (_performanceByPar?.HasValidData == true)
                    {
                        <div class="report-par-visual pa-4">
                            @{
                                var parItems = new (string Label, int Par, double Avg, double RelPar, int Count)[]
                                {
                                    ("Par 3", 3, _performanceByPar.Par3Average, _performanceByPar.Par3RelativeToPar, _performanceByPar.Par3Count),
                                    ("Par 4", 4, _performanceByPar.Par4Average, _performanceByPar.Par4RelativeToPar, _performanceByPar.Par4Count),
                                    ("Par 5", 5, _performanceByPar.Par5Average, _performanceByPar.Par5RelativeToPar, _performanceByPar.Par5Count)
                                };
                            }
                            @foreach (var par in parItems.Where(p => p.Count > 0))
                            {
                                var relColor = par.RelPar <= 0 ? "stat-under-par" : "stat-over-par";
                                <div class="report-par-item">
                                    <div class="report-par-header">
                                        <span class="report-par-label">@par.Label</span>
                                        <span class="report-par-count">@par.Count holes</span>
                                    </div>
                                    <div class="report-par-stats">
                                        <div class="report-par-avg">
                                            <span class="report-par-avg-value">@par.Avg.ToString("F2")</span>
                                            <span class="report-par-avg-label">avg strokes</span>
                                        </div>
                                        <div class="report-par-vs">
                                            <span class="report-par-vs-value @relColor">@(par.RelPar >= 0 ? "+" : "")@par.RelPar.ToString("F2")</span>
                                            <span class="report-par-vs-label">vs par</span>
                                        </div>
                                        <div class="report-par-bar-track">
                                            @{
                                                var barWidth = Math.Min(Math.Abs(par.RelPar) / 2.0 * 100, 100);
                                                var barColor = par.RelPar <= 0 ? "#43A047" : "#E53935";
                                                var barSide = par.RelPar <= 0 ? "right" : "left";
                                            }
                                            <div class="report-par-bar-center"></div>
                                            @if (par.RelPar <= 0)
                                            {
                                                <div class="report-par-bar-fill report-par-bar-left" style="width: @barWidth.ToString("F1", CultureInfo.InvariantCulture)%; background: @barColor;"></div>
                                            }
                                            else
                                            {
                                                <div class="report-par-bar-fill report-par-bar-right" style="width: @barWidth.ToString("F1", CultureInfo.InvariantCulture)%; background: @barColor;"></div>
                                            }
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <div class="report-analytics-empty pa-4">
                            <MudAlert Severity="Severity.Info" Dense="true">No par data for selected filters.</MudAlert>
                        </div>
                    }
                </div>
            </MudItem>
        </MudGrid>

        <!-- Head-to-Head Comparison Table -->
        @if (_comparisonResult?.Summaries != null && _comparisonResult.Summaries.Count > 1)
        {
            <div class="gp-card report-comparison-section mt-4">
                <MudText Typo="Typo.h6" Class="pa-4 pb-2">⚔️ Head-to-Head Comparison</MudText>
                <MudSimpleTable Dense="true" Hover="true" Class="report-comparison-table">
                    <thead>
                        <tr>
                            <th>Player</th>
                            <th>Rounds</th>
                            <th>Avg Score</th>
                            <th>Avg vs Par</th>
                            <th>Best</th>
                            <th>Shared Rounds</th>
                            <th>W/L/T</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var summary in _comparisonResult.Summaries)
                        {
                            var isPrimary = summary.PlayerId == PlayerId;
                            <tr class="@(isPrimary ? "report-comparison-primary" : "")">
                                <td><strong>@summary.PlayerName</strong> @(isPrimary ? " (You)" : "")</td>
                                <td>@summary.TotalRounds</td>
                                <td>@summary.AverageScore.ToString("F1")</td>
                                <td>
                                    @{
                                        var compSvp = summary.AverageToPar;
                                        var compClass = compSvp < 0 ? "stat-under-par" : compSvp > 0 ? "stat-over-par" : "stat-level-par";
                                    }
                                    <span class="@compClass">@(compSvp >= 0 ? "+" : "")@compSvp.ToString("F1")</span>
                                </td>
                                <td>@summary.BestScore</td>
                                <td>@(isPrimary ? "-" : summary.SharedRounds.ToString())</td>
                                <td>@(isPrimary ? "-" : $"{summary.Wins}/{summary.Losses}/{summary.Ties}")</td>
                            </tr>
                        }
                    </tbody>
                </MudSimpleTable>
            </div>
        }

        <!-- Rounds Table (at bottom, after analytics) -->
        <div class="gp-card report-rounds-section mt-4">
            <div class="report-section-header">
                <MudText Typo="Typo.h6">🏌️ Rounds Included (@_viewModel.PerformanceData.Count)</MudText>
            </div>
            <MudDataGrid T="PlayerPerformanceDataPoint" Items="@_viewModel.PerformanceData.OrderByDescending(d => d.Date)" 
                         Dense="true" Hover="true" RowClick="@OnRoundRowClick" Class="report-data-grid"
                         SortMode="SortMode.Multiple" Filterable="false">
                <Columns>
                    <PropertyColumn Property="x => x.Date" Title="Date" Format="dd MMM yyyy" />
                    <PropertyColumn Property="x => x.CourseName" Title="Course" />
                    <PropertyColumn Property="x => x.HolesPlayed" Title="Holes" />
                    <PropertyColumn Property="x => x.TotalScore" Title="Score" />
                    <PropertyColumn Property="x => x.TotalPar" Title="Par" />
                    <TemplateColumn Title="vs Par" SortBy="@(x => x.ScoreVsPar)">
                        <CellTemplate>
                            @{
                                var svp = context.Item.ScoreVsPar;
                                var svpClass = svp < 0 ? "stat-under-par" : svp > 0 ? "stat-over-par" : "stat-level-par";
                            }
                            <span class="report-score-badge @svpClass">@(svp >= 0 ? "+" : "")@svp</span>
                        </CellTemplate>
                    </TemplateColumn>
                </Columns>
            </MudDataGrid>
        </div>
    }
    else
    {
        <div class="report-empty">
            <MudIcon Icon="@Icons.Material.Filled.BarChart" Size="Size.Large" Color="Color.Secondary" />
            <MudText Typo="Typo.h6" Color="Color.Secondary" Class="mt-2">No Data Available</MudText>
            <MudText Typo="Typo.body2" Color="Color.Secondary">No completed rounds found for this player with the selected filters.</MudText>
        </div>
    }
}

@code {
    [Parameter]
    public int PlayerId { get; set; }

    private PlayerReportViewModel _viewModel = new();
    private bool _isInitialLoading = true;
    private bool _isFilterLoading = false;
    private CultureInfo _ukCulture = new("en-GB");

    // Comparison
    private List<Player> _availablePlayers = new();
    private List<Player> _comparisonPlayers = new();
    private HashSet<int> _comparisonPlayerIds = new();
    private PlayerComparisonResult? _comparisonResult;

    // Round drill-down
    private RoundDetailSummary? _selectedRoundDetail;

    // Filter properties
    private int? _selectedCourseId;
    public int? SelectedCourseId 
    { 
        get => _selectedCourseId; 
        set { if (_selectedCourseId != value) { _selectedCourseId = value; InvokeAsync(OnFilterChanged); } } 
    }

    private int? _selectedHolesPlayed;
    public int? SelectedHolesPlayed 
    { 
        get => _selectedHolesPlayed; 
        set { if (_selectedHolesPlayed != value) { _selectedHolesPlayed = value; InvokeAsync(OnFilterChanged); } } 
    }

    private RoundTypeOption? _selectedRoundType;
    public RoundTypeOption? SelectedRoundType 
    { 
        get => _selectedRoundType; 
        set { if (_selectedRoundType != value) { _selectedRoundType = value; InvokeAsync(OnFilterChanged); } } 
    }

    private DateTime? _startDate;
    public DateTime? StartDate 
    { 
        get => _startDate; 
        set { if (_startDate != value) { _startDate = value; InvokeAsync(OnFilterChanged); } } 
    }

    private DateTime? _endDate;
    public DateTime? EndDate 
    { 
        get => _endDate; 
        set { if (_endDate != value) { _endDate = value; InvokeAsync(OnFilterChanged); } } 
    }

    private bool _showScoreVsPar = true;
    public bool ShowScoreVsPar 
    { 
        get => _showScoreVsPar; 
        set 
        { 
            if (_showScoreVsPar != value) 
            { 
                _showScoreVsPar = value; 
                UpdateChartDisplayMode();
                StateHasChanged();
            } 
        } 
    }

    // Add player selector
    private int? _addPlayerSelection;
    public int? AddPlayerSelection
    {
        get => _addPlayerSelection;
        set
        {
            _addPlayerSelection = value;
            if (value.HasValue && value > 0)
            {
                AddComparisonPlayer(value.Value);
                _addPlayerSelection = null;
            }
        }
    }

    // Chart data
    private List<ChartSeries> _series = new();
    private string[] _xAxisLabels = Array.Empty<string>();
    private ChartOptions _lineChartOptions = new();
    private AxisChartOptions _lineAxisChartOptions = new();
    private ScoringDistribution? _scoringDistribution;
    private PerformanceByPar? _performanceByPar;

    // AI Insights
    private string? _currentUserId;
    private bool _aiInsightEnabled;
    private bool _aiLoading;
    private bool _aiPanelExpanded
    {
        get => _aiPanelExpandedBacking;
        set
        {
            _aiPanelExpandedBacking = value;
            if (value && _aiInsight == null && !_aiLoading)
                _ = LoadPlayerReportInsights();
        }
    }
    private bool _aiPanelExpandedBacking;
    private AiInsightResult? _aiInsight;

    private List<BreadcrumbItem> _breadcrumbs = new();

    protected override async Task OnInitializedAsync()
    {
        _aiInsightEnabled = Configuration.GetValue<bool>("AiInsights:Enabled");

        // Load available players for comparison
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var userId = authState.User.FindFirstValue(ClaimTypes.NameIdentifier);
        _currentUserId = userId;
        if (!string.IsNullOrEmpty(userId))
        {
            var isAdmin = authState.User.IsInRole("Admin");
            _availablePlayers = await PlayerService.GetAllPlayersAsync(userId, isAdmin);
        }

        await LoadReportData();
        _isInitialLoading = false;
    }

    private void AddComparisonPlayer(int playerId)
    {
        var player = _availablePlayers.FirstOrDefault(p => p.PlayerId == playerId);
        if (player != null && !_comparisonPlayerIds.Contains(playerId))
        {
            _comparisonPlayers.Add(player);
            _comparisonPlayerIds.Add(playerId);
            InvokeAsync(OnFilterChanged);
        }
    }

    private void RemoveComparisonPlayer(int playerId)
    {
        _comparisonPlayers.RemoveAll(p => p.PlayerId == playerId);
        _comparisonPlayerIds.Remove(playerId);
        _comparisonResult = null;
        InvokeAsync(OnFilterChanged);
    }

    private async Task OnFilterChanged()
    {
        _isFilterLoading = true;
        _selectedRoundDetail = null;
        StateHasChanged();
        
        try
        {
            await LoadReportData();
        }
        finally
        {
            _isFilterLoading = false;
            StateHasChanged();
        }
    }

    private void UpdateChartDisplayMode()
    {
        PrepareChartData();
    }

    private async Task LoadPlayerReportInsights()
    {
        _aiLoading = true;
        StateHasChanged();
        try
        {
            _aiInsight = await AiInsightService.GetPlayerReportInsightsAsync(
                _currentUserId!, PlayerId, _selectedCourseId, _selectedHolesPlayed);
        }
        catch (Exception ex)
        {
            _aiInsight = new AiInsightResult
            {
                Success = false,
                ErrorMessage = "Could not load AI insights."
            };
        }
        finally
        {
            _aiLoading = false;
            StateHasChanged();
        }
    }

    private async Task LoadReportData()
    {
        try
        {
            // When comparison players are selected, filter all data to shared rounds only (head-to-head mode)
            var sharedWith = _comparisonPlayerIds.Any() ? _comparisonPlayerIds.ToList() : null;

            _viewModel = await ReportService.GetPlayerReportViewModelAsync(PlayerId, _selectedCourseId, _selectedHolesPlayed, _selectedRoundType, _startDate, _endDate, sharedWith);
            _scoringDistribution = await ReportService.GetScoringDistributionAsync(PlayerId, _selectedCourseId, _selectedHolesPlayed, _selectedRoundType, _startDate, _endDate, sharedWith);
            _performanceByPar = await ReportService.GetPerformanceByParAsync(PlayerId, _selectedCourseId, _selectedHolesPlayed, _selectedRoundType, _startDate, _endDate, sharedWith);

            // Load comparison data if players selected
            if (_comparisonPlayerIds.Any())
            {
                _comparisonResult = await ReportService.GetPlayerComparisonAsync(
                    PlayerId, _comparisonPlayerIds.ToList(),
                    _selectedCourseId, _selectedHolesPlayed, _selectedRoundType, _startDate, _endDate);
            }
            else
            {
                _comparisonResult = null;
            }

            if (_viewModel.Player is not null)
            {
                _breadcrumbs = new List<BreadcrumbItem>
                {
                    new BreadcrumbItem("Players", href: "/players"),
                    new BreadcrumbItem($"{_viewModel.Player.FirstName} {_viewModel.Player.LastName}", href: null, disabled: true)
                };
            }

            PrepareChartData();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error loading report data: {ex.Message}", Severity.Error);
        }
    }

    private void PrepareChartData()
    {
        if (_viewModel.PerformanceData is null || !_viewModel.PerformanceData.Any())
        {
            _series.Clear();
            _xAxisLabels = Array.Empty<string>();
            return;
        }

        var seriesList = new List<ChartSeries>();
        var primaryData = _viewModel.PerformanceData.OrderBy(d => d.Date).ToList();

        // Primary player series
        var primarySeriesData = _showScoreVsPar
            ? primaryData.Select(d => (double)d.ScoreVsPar).ToArray()
            : primaryData.Select(d => (double)d.TotalScore).ToArray();
        seriesList.Add(new ChartSeries { Name = _viewModel.Player?.FirstName ?? "You", Data = primarySeriesData });

        // X-axis labels from primary player's dates
        _xAxisLabels = GenerateXAxisLabels(primaryData.Select(d => d.Date).ToList());

        // Add comparison series (each plotted by index, like mobile)
        if (_comparisonResult?.PlayerSeries != null)
        {
            foreach (var cs in _comparisonResult.PlayerSeries.Where(s => s.PlayerId != PlayerId))
            {
                var compData = cs.DataPoints.OrderBy(d => d.Date).ToList();
                var compSeriesData = _showScoreVsPar
                    ? compData.Select(d => (double)d.ScoreVsPar).ToArray()
                    : compData.Select(d => (double)d.TotalScore).ToArray();
                seriesList.Add(new ChartSeries { Name = cs.PlayerName.Split(' ')[0], Data = compSeriesData });
            }
        }

        _series = seriesList;

        _lineChartOptions = new ChartOptions
        {
            LineStrokeWidth = 2,
            ChartPalette = new[] { "#1B5E20", "#E65100", "#1565C0", "#6A1B9A", "#BF360C" }
        };

        _lineAxisChartOptions = new AxisChartOptions
        {
            XAxisLabelRotation = 30,
            MatchBoundsToSize = true
        };
    }

    private string[] GenerateXAxisLabels(List<DateTime> dates)
    {
        if (dates.Count <= 10)
            return dates.Select(d => d.ToString("dd MMM")).ToArray();
        else if (dates.Count <= 25)
            return dates.Select((d, i) => i % 2 == 0 ? d.ToString("dd MMM") : "").ToArray();
        else
        {
            var labels = new string[dates.Count];
            for (int i = 0; i < dates.Count; i++) labels[i] = "";
            labels[0] = dates[0].ToString("dd MMM");
            labels[dates.Count - 1] = dates[dates.Count - 1].ToString("dd MMM");
            int step = Math.Max(1, dates.Count / 8);
            for (int i = step; i < dates.Count - 1; i += step)
                labels[i] = dates[i].ToString("dd MMM");
            return labels;
        }
    }

    private string[] GenerateXAxisLabels(List<PlayerPerformanceDataPoint> data)
    {
        return GenerateXAxisLabels(data.Select(d => d.Date).ToList());
    }

    private async Task OnRoundRowClick(DataGridRowClickEventArgs<PlayerPerformanceDataPoint> args)
    {
        if (args.Item.RoundId > 0)
        {
            _selectedRoundDetail = await ReportService.GetRoundDetailAsync(args.Item.RoundId, PlayerId);
            await ShowRoundDetailDialog();
        }
    }

    private async Task ShowRoundDetailDialog()
    {
        if (_selectedRoundDetail == null) return;

        var parameters = new DialogParameters<RoundDetailDialog>
        {
            { x => x.RoundDetail, _selectedRoundDetail }
        };

        var options = new DialogOptions
        {
            MaxWidth = MaxWidth.Medium,
            FullWidth = true,
            CloseButton = true,
            CloseOnEscapeKey = true
        };

        await DialogService.ShowAsync<RoundDetailDialog>("Round Detail", parameters, options);
    }

    private void CloseRoundDetail()
    {
        _selectedRoundDetail = null;
    }
}