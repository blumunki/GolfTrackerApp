@page "/players"
@attribute [Authorize]
@rendermode InteractiveServer
@implements IDisposable
@inject IPlayerService PlayerService
@inject IConnectionService ConnectionService
@inject IMergeService MergeService
@inject IReportService ReportService
@inject NavigationManager NavigationManager
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject AuthenticationStateProvider AuthenticationStateProvider
@using System.Security.Claims
@using GolfTrackerApp.Web.Models
@using GolfTrackerApp.Web.Components.Shared
@using GolfTrackerApp.Web.Services
@using Microsoft.AspNetCore.Authorization

<PageTitle>Players</PageTitle>

@if (_isLoading)
{
    <div class="report-loading">
        <MudProgressCircular Indeterminate="true" Size="Size.Large" Color="Color.Primary" />
        <MudText Typo="Typo.body1" Class="mt-3" Color="Color.Secondary">Loading players...</MudText>
    </div>
}
else
{
    @* ── My Profile Header ── *@
    <div class="player-profile-header">
        <div class="player-profile-top">
            <div class="player-profile-info">
                <div class="player-avatar-large">
                    @if (_myProfile != null)
                    {
                        @($"{(_myProfile.FirstName?.Length > 0 ? _myProfile.FirstName[..1] : "")}{(_myProfile.LastName?.Length > 0 ? _myProfile.LastName[..1] : "")}")
                    }
                    else
                    {
                        <span>?</span>
                    }
                </div>
                <div>
                    @if (_myProfile != null)
                    {
                        <h2 class="player-profile-name">@_myProfile.FirstName @_myProfile.LastName</h2>
                        <div class="player-profile-meta">
                            <span class="meta-item">
                                <MudIcon Icon="@Icons.Material.Filled.SportsGolf" Size="Size.Small" />
                                Handicap: @(_myProfile.Handicap.HasValue ? _myProfile.Handicap.Value.ToString("N1") : "Not set")
                            </span>
                            @if (_myStats != null && _myStats.RoundCount > 0)
                            {
                                <span class="meta-item">
                                    <MudIcon Icon="@Icons.Material.Filled.Flag" Size="Size.Small" />
                                    @_myStats.RoundCount rounds played
                                </span>
                                @if (_myStats.LastPlayed.HasValue)
                                {
                                    <span class="meta-item">
                                        <MudIcon Icon="@Icons.Material.Filled.CalendarToday" Size="Size.Small" />
                                        Last: @_myStats.LastPlayed.Value.ToString("dd MMM yyyy")
                                    </span>
                                }
                            }
                        </div>
                    }
                    else
                    {
                        <h2 class="player-profile-name">My Profile</h2>
                        <div class="player-profile-meta">
                            <span class="meta-item" style="color:rgba(255,200,100,0.9);">No player profile found</span>
                        </div>
                    }
                </div>
            </div>
            @if (_myProfile != null)
            {
                <div class="player-profile-actions">
                    <MudButton Variant="Variant.Outlined"
                               Style="color:white; border-color:rgba(255,255,255,0.3);"
                               StartIcon="@Icons.Material.Filled.Timeline"
                               Href="@($"/players/{_myProfile.PlayerId}/report")" Size="Size.Small">
                        My Report
                    </MudButton>
                    <MudButton Variant="Variant.Outlined"
                               Style="color:white; border-color:rgba(255,255,255,0.3);"
                               StartIcon="@Icons.Material.Filled.Edit"
                               OnClick="@(() => EditPlayer(_myProfile.PlayerId))" Size="Size.Small">
                        Edit Profile
                    </MudButton>
                </div>
            }
        </div>
    </div>

    @* ── My Profile Quick Stats ── *@
    @if (_myStats != null && _myStats.RoundCount > 0)
    {
        <div class="club-stats-row">
            <div class="club-stat-card">
                <div class="stat-icon">🏌️</div>
                <div class="stat-value">@_myStats.RoundCount</div>
                <div class="stat-label">Rounds</div>
            </div>
            <div class="club-stat-card accent-green">
                <div class="stat-icon">⭐</div>
                <div class="stat-value">@(_myStats.BestScore?.ToString() ?? "-")</div>
                <div class="stat-label">Best Score</div>
            </div>
            <div class="club-stat-card accent-blue">
                <div class="stat-icon">📊</div>
                <div class="stat-value">@(_myStats.AverageScore?.ToString("F1") ?? "-")</div>
                <div class="stat-label">Avg Score</div>
            </div>
            <div class="club-stat-card accent-amber">
                <div class="stat-icon">⛳</div>
                <div class="stat-value">@GolfHelpers.FormatVsPar(_myStats.AverageVsPar)</div>
                <div class="stat-label">Avg vs Par</div>
            </div>
        </div>
    }

    @* ── Pending Merge Requests ── *@
    @if (_pendingMergeRequests.Any())
    {
        <div class="players-section-header">
            <div class="players-section-title">
                <MudIcon Icon="@Icons.Material.Filled.MergeType" Size="Size.Small" Color="Color.Info" />
                Data Transfer Requests
                <span class="players-section-badge badge-info">@_pendingMergeRequests.Count</span>
            </div>
        </div>
        @foreach (var request in _pendingMergeRequests)
        {
            <div class="player-notification-card merge-request">
                <div class="notification-info">
                    <div class="notification-title">@(request.RequestingUser?.UserName ?? "Unknown") wants to transfer data</div>
                    <div class="notification-subtitle">Player: @(request.SourcePlayer?.FirstName) @(request.SourcePlayer?.LastName)</div>
                    @if (!string.IsNullOrEmpty(request.Message))
                    {
                        <div class="notification-message">"@request.Message"</div>
                    }
                </div>
                <div class="notification-actions">
                    <MudButton Variant="Variant.Filled" Color="Color.Success" Size="Size.Small"
                               StartIcon="@Icons.Material.Filled.Check"
                               OnClick="@(() => AcceptMergeRequest(request))">Accept</MudButton>
                    <MudButton Variant="Variant.Outlined" Color="Color.Error" Size="Size.Small"
                               StartIcon="@Icons.Material.Filled.Close"
                               OnClick="@(() => DeclineMergeRequest(request))">Decline</MudButton>
                </div>
            </div>
        }
    }

    @* ── Pending Connection Requests ── *@
    @if (_pendingRequests.Any())
    {
        <div class="players-section-header">
            <div class="players-section-title">
                <MudIcon Icon="@Icons.Material.Filled.PersonAdd" Size="Size.Small" Color="Color.Success" />
                Connection Requests
                <span class="players-section-badge badge-success">@_pendingRequests.Count</span>
            </div>
        </div>
        @foreach (var request in _pendingRequests)
        {
            <div class="player-notification-card connection-request">
                <div class="notification-info">
                    <div class="notification-title">@(request.RequestingUser?.UserName ?? "Unknown User")</div>
                    <div class="notification-subtitle">@(request.RequestingUser?.Email ?? "")</div>
                </div>
                <div class="notification-actions">
                    <MudButton Variant="Variant.Filled" Color="Color.Success" Size="Size.Small"
                               StartIcon="@Icons.Material.Filled.Check"
                               OnClick="@(() => AcceptRequest(request))">Accept</MudButton>
                    <MudButton Variant="Variant.Outlined" Color="Color.Error" Size="Size.Small"
                               StartIcon="@Icons.Material.Filled.Close"
                               OnClick="@(() => DeclineRequest(request))">Decline</MudButton>
                </div>
            </div>
        }
    }

    @* ── Connections Section ── *@
    <div class="players-section-header">
        <div class="players-section-title">
            <MudIcon Icon="@Icons.Material.Filled.People" Size="Size.Small" Color="Color.Primary" />
            My Connections
            <span class="players-section-badge badge-primary">@_connections.Count</span>
        </div>
    </div>

    @* Search for new connections *@
    <div class="user-search-box">
        <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mb-2">Find users to connect with</MudText>
        <MudTextField @bind-Value="_userSearchTerm"
                      Placeholder="Search by name or email..."
                      Variant="Variant.Outlined"
                      Adornment="Adornment.End"
                      AdornmentIcon="@Icons.Material.Filled.Search"
                      OnKeyUp="@OnUserSearchKeyUp"
                      Immediate="true"
                      Margin="Margin.Dense" />
        @if (_userSearchResults.Any())
        {
            <div style="margin-top:8px;">
                @foreach (var user in _userSearchResults)
                {
                    <div class="user-search-result">
                        <div class="user-search-result-info">
                            <div class="user-search-avatar">@GetInitials(user.DisplayName)</div>
                            <div>
                                <div style="font-weight:600; font-size:0.9rem; color:#1a1a2e;">@user.DisplayName</div>
                                <div style="font-size:0.75rem; color:#9ca3af;">@user.Email</div>
                            </div>
                        </div>
                        @if (user.ExistingConnectionStatus == ConnectionStatus.Accepted)
                        {
                            <MudChip T="string" Color="Color.Success" Size="Size.Small">Connected</MudChip>
                        }
                        else if (user.ExistingConnectionStatus == ConnectionStatus.Pending)
                        {
                            @if (user.IsRequestSentByCurrentUser)
                            {
                                <MudChip T="string" Color="Color.Warning" Size="Size.Small">Request Sent</MudChip>
                            }
                            else
                            {
                                <MudButton Size="Size.Small" Variant="Variant.Filled" Color="Color.Success"
                                           OnClick="@(() => AcceptFromSearch(user))">Accept</MudButton>
                            }
                        }
                        else
                        {
                            <MudButton Size="Size.Small" Variant="Variant.Filled" Color="Color.Primary"
                                       StartIcon="@Icons.Material.Filled.PersonAdd"
                                       OnClick="@(() => SendConnectionRequest(user))">Connect</MudButton>
                        }
                    </div>
                }
            </div>
        }
    </div>

    @* Connection Cards *@
    @if (_connections.Any())
    {
        <div class="connection-card-grid">
            @foreach (var connection in _connections)
            {
                var connectedUser = connection.RequestingUserId == _currentUserId
                    ? connection.TargetUser
                    : connection.RequestingUser;
                var connectedUserId = connectedUser?.Id ?? "";
                var connectedPlayer = connectedUserId != "" && _connectedUserProfiles.ContainsKey(connectedUserId)
                    ? _connectedUserProfiles[connectedUserId]
                    : null;
                var displayName = connectedPlayer != null
                    ? $"{connectedPlayer.FirstName} {connectedPlayer.LastName}"
                    : (connectedUser?.UserName ?? "Unknown");
                var connStats = connectedPlayer != null && _playerStats.ContainsKey(connectedPlayer.PlayerId)
                    ? _playerStats[connectedPlayer.PlayerId]
                    : null;

                <div class="connection-card">
                    <div class="connection-card-header">
                        <div class="connection-avatar">@GetInitials(displayName)</div>
                        <div>
                            <div class="connection-name">@displayName</div>
                            <div class="connection-email">@(connectedUser?.Email ?? "")</div>
                            <div class="connection-since">Connected @(connection.RespondedAt?.ToString("d MMM yyyy") ?? "")</div>
                        </div>
                    </div>

                    @if (connStats != null && connStats.RoundCount > 0)
                    {
                        <div class="player-card-stats">
                            <div class="player-mini-stat">
                                <div class="mini-value">@connStats.RoundCount</div>
                                <div class="mini-label">Rounds</div>
                            </div>
                            <div class="player-mini-stat accent-green">
                                <div class="mini-value">@(connStats.BestScore?.ToString() ?? "-")</div>
                                <div class="mini-label">Best</div>
                            </div>
                            <div class="player-mini-stat accent-blue">
                                <div class="mini-value">@(connStats.AverageScore?.ToString("F1") ?? "-")</div>
                                <div class="mini-label">Avg</div>
                            </div>
                        </div>
                    }

                    <div class="connection-card-actions">
                        <MudButton Variant="Variant.Text" Color="Color.Info" Size="Size.Small"
                                   StartIcon="@Icons.Material.Filled.Timeline"
                                   Disabled="@(string.IsNullOrEmpty(connectedUserId))"
                                   OnClick="@(async () => { if (!string.IsNullOrEmpty(connectedUserId)) await ViewConnectedPlayerReport(connectedUserId); })">
                            Report
                        </MudButton>
                        <MudButton Variant="Variant.Text" Color="Color.Primary" Size="Size.Small"
                                   StartIcon="@Icons.Material.Filled.MergeType"
                                   OnClick="@(() => OpenMergeDialog(connectedUserId, displayName))">
                            Transfer
                        </MudButton>
                        <MudButton Variant="Variant.Text" Color="Color.Error" Size="Size.Small"
                                   StartIcon="@Icons.Material.Filled.PersonRemove"
                                   OnClick="@(() => RemoveConnection(connection))">
                            Remove
                        </MudButton>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="players-empty-state">
            <div class="players-empty-icon">🤝</div>
            <MudText Typo="Typo.body2" Color="Color.Secondary">No connections yet. Search above to find other golfers.</MudText>
        </div>
    }

    @* Sent Requests *@
    @if (_sentRequests.Any())
    {
        <div class="players-section-header" style="margin-top:12px;">
            <div class="players-section-title" style="font-size:0.9rem;">
                <MudIcon Icon="@Icons.Material.Filled.Send" Size="Size.Small" Color="Color.Warning" />
                Pending Sent Requests
            </div>
        </div>
        @foreach (var request in _sentRequests)
        {
            <div class="sent-request-row">
                <div>
                    <span class="sent-request-info">@(request.TargetUser?.UserName ?? "Unknown")</span>
                    <span class="sent-request-date"> · Sent @request.RequestedAt.ToString("d MMM yyyy")</span>
                </div>
                <MudIconButton Icon="@Icons.Material.Filled.Cancel" Size="Size.Small" Color="Color.Warning"
                               OnClick="@(() => CancelRequest(request))" />
            </div>
        }
    }

    @* ── Managed Players Section ── *@
    <div class="players-section-header">
        <div class="players-section-title">
            <MudIcon Icon="@Icons.Material.Filled.Groups" Size="Size.Small" Color="Color.Secondary" />
            Managed Players
            <span class="players-section-badge badge-primary">@(_managedPlayers?.Count ?? 0)</span>
        </div>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="GoToAddPlayerPage"
                   StartIcon="@Icons.Material.Filled.PersonAdd" Size="Size.Small">
            Add Player
        </MudButton>
    </div>

    @* Managed Player Search *@
    @if (_managedPlayers?.Count > 5)
    {
        <div style="margin-bottom:12px;">
            <MudTextField @bind-Value="searchString"
                          Placeholder="Filter by name..."
                          Variant="Variant.Outlined"
                          Adornment="Adornment.Start"
                          AdornmentIcon="@Icons.Material.Filled.Search"
                          DebounceInterval="300"
                          OnDebounceIntervalElapsed="OnSearchTextChanged"
                          Margin="Margin.Dense" />
        </div>
    }

    @if (_managedPlayers != null && _managedPlayers.Any())
    {
        <div class="player-card-grid">
            @foreach (var player in _managedPlayers)
            {
                var stats = _playerStats.ContainsKey(player.PlayerId) ? _playerStats[player.PlayerId] : null;

                <div class="player-card" @onclick="@(() => NavigationManager.NavigateTo($"/players/{player.PlayerId}/report"))">
                    <div class="player-card-top">
                        <div class="player-card-avatar">
                            @($"{(player.FirstName?.Length > 0 ? player.FirstName[..1] : "")}{(player.LastName?.Length > 0 ? player.LastName[..1] : "")}")
                        </div>
                        <div style="flex:1;">
                            <div class="player-card-name">@player.FirstName @player.LastName</div>
                            <div class="player-card-handicap">
                                Handicap: @(player.Handicap.HasValue ? player.Handicap.Value.ToString("N1") : "N/A")
                            </div>
                        </div>
                    </div>

                    @if (stats != null && stats.RoundCount > 0)
                    {
                        <div class="player-card-stats">
                            <div class="player-mini-stat">
                                <div class="mini-value">@stats.RoundCount</div>
                                <div class="mini-label">Rounds</div>
                            </div>
                            <div class="player-mini-stat accent-green">
                                <div class="mini-value">@(stats.BestScore?.ToString() ?? "-")</div>
                                <div class="mini-label">Best</div>
                            </div>
                            <div class="player-mini-stat accent-blue">
                                <div class="mini-value">@(stats.AverageScore?.ToString("F1") ?? "-")</div>
                                <div class="mini-label">Avg</div>
                            </div>
                        </div>
                    }

                    <div class="player-card-actions" @onclick:stopPropagation="true">
                        <MudButton Variant="Variant.Text" Color="Color.Info" Size="Size.Small"
                                   StartIcon="@Icons.Material.Filled.Timeline"
                                   Href="@($"/players/{player.PlayerId}/report")">Report</MudButton>
                        <MudButton Variant="Variant.Text" Color="Color.Primary" Size="Size.Small"
                                   StartIcon="@Icons.Material.Filled.Edit"
                                   OnClick="@(() => EditPlayer(player.PlayerId))">Edit</MudButton>
                        <MudButton Variant="Variant.Text" Color="Color.Error" Size="Size.Small"
                                   StartIcon="@Icons.Material.Filled.Delete"
                                   OnClick="@(() => PrepareDeletePlayer(player))">Delete</MudButton>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="players-empty-state">
            <div class="players-empty-icon">👥</div>
            <MudText Typo="Typo.body2" Color="Color.Secondary">No managed players. Add players you play with to track their scores.</MudText>
        </div>
    }
}

@code {
    private List<Player>? _managedPlayers;
    private Player? _myProfile;
    private PlayerQuickStats? _myStats;
    private Dictionary<int, PlayerQuickStats> _playerStats = new();
    private bool _isLoading = true;
    private string searchString = "";
    private string? _currentUserId;

    // Connection-related fields
    private List<PlayerConnection> _pendingRequests = new();
    private List<PlayerConnection> _connections = new();
    private List<PlayerConnection> _sentRequests = new();
    private Dictionary<string, Player> _connectedUserProfiles = new();
    private string _userSearchTerm = "";
    private List<UserSearchResult> _userSearchResults = new();
    private System.Timers.Timer? _searchDebounceTimer;

    // Merge-related fields
    private List<PlayerMergeRequest> _pendingMergeRequests = new();
    private List<PlayerMergeRequest> _sentMergeRequests = new();

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        _currentUserId = user.FindFirstValue(ClaimTypes.NameIdentifier);

        // Load all data in parallel
        await Task.WhenAll(
            LoadMyProfile(),
            LoadManagedPlayers(),
            LoadConnections(),
            LoadMergeRequests()
        );

        // Load stats for my profile
        if (_myProfile != null)
        {
            _myStats = await ReportService.GetPlayerQuickStatsAsync(_myProfile.PlayerId);
        }

        // Batch load stats for all managed players + connected players
        var allPlayerIds = new List<int>();
        if (_managedPlayers != null)
            allPlayerIds.AddRange(_managedPlayers.Select(p => p.PlayerId));
        foreach (var profile in _connectedUserProfiles.Values)
            allPlayerIds.Add(profile.PlayerId);

        if (allPlayerIds.Any())
        {
            _playerStats = await ReportService.GetBatchPlayerQuickStatsAsync(allPlayerIds.Distinct());
        }

        _isLoading = false;
    }

    private async Task LoadMyProfile()
    {
        if (string.IsNullOrEmpty(_currentUserId)) return;
        try
        {
            _myProfile = await PlayerService.GetPlayerByApplicationUserIdAsync(_currentUserId);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error loading profile: {ex.Message}", Severity.Error);
        }
    }

    private async Task LoadConnections()
    {
        if (string.IsNullOrEmpty(_currentUserId)) return;
        try
        {
            _pendingRequests = await ConnectionService.GetPendingRequestsReceivedAsync(_currentUserId);
            _connections = await ConnectionService.GetConnectionsAsync(_currentUserId);
            _sentRequests = await ConnectionService.GetPendingRequestsSentAsync(_currentUserId);

            _connectedUserProfiles.Clear();
            foreach (var connection in _connections)
            {
                var connectedUserId = connection.RequestingUserId == _currentUserId
                    ? connection.TargetUserId
                    : connection.RequestingUserId;
                if (!_connectedUserProfiles.ContainsKey(connectedUserId))
                {
                    var player = await PlayerService.GetPlayerByApplicationUserIdAsync(connectedUserId);
                    if (player != null) _connectedUserProfiles[connectedUserId] = player;
                }
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error loading connections: {ex.Message}", Severity.Error);
        }
    }

    private async Task LoadMergeRequests()
    {
        if (string.IsNullOrEmpty(_currentUserId)) return;
        try
        {
            _pendingMergeRequests = await MergeService.GetPendingMergeRequestsReceivedAsync(_currentUserId);
            _sentMergeRequests = await MergeService.GetPendingMergeRequestsSentAsync(_currentUserId);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error loading merge requests: {ex.Message}", Severity.Error);
        }
    }

    private async Task LoadManagedPlayers()
    {
        try
        {
            if (string.IsNullOrEmpty(_currentUserId)) return;
            var allPlayers = await PlayerService.SearchPlayersAsync(_currentUserId, false, searchString);
            _managedPlayers = allPlayers.Where(p => string.IsNullOrEmpty(p.ApplicationUserId)).ToList();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error loading players: {ex.Message}", Severity.Error);
        }
    }

    private async Task OnSearchTextChanged(string text)
    {
        searchString = text;
        await LoadManagedPlayers();
    }

    private string GetInitials(string? name)
    {
        if (string.IsNullOrWhiteSpace(name)) return "?";
        var parts = name.Trim().Split(' ', StringSplitOptions.RemoveEmptyEntries);
        return parts.Length >= 2 ? $"{parts[0][..1]}{parts[^1][..1]}" : parts[0][..1].ToString();
    }

    // ── User Search ──
    private void OnUserSearchKeyUp(KeyboardEventArgs e)
    {
        _searchDebounceTimer?.Stop();
        _searchDebounceTimer?.Dispose();
        _searchDebounceTimer = new System.Timers.Timer(300);
        _searchDebounceTimer.Elapsed += async (sender, args) =>
        {
            _searchDebounceTimer?.Stop();
            await InvokeAsync(async () => { await SearchUsers(); StateHasChanged(); });
        };
        _searchDebounceTimer.AutoReset = false;
        _searchDebounceTimer.Start();
    }

    private async Task SearchUsers()
    {
        if (string.IsNullOrEmpty(_currentUserId) || string.IsNullOrWhiteSpace(_userSearchTerm))
        { _userSearchResults = new(); return; }
        try { _userSearchResults = await ConnectionService.SearchUsersAsync(_userSearchTerm, _currentUserId); }
        catch (Exception ex) { Snackbar.Add($"Error searching users: {ex.Message}", Severity.Error); }
    }

    // ── Connection Actions ──
    private async Task SendConnectionRequest(UserSearchResult user)
    {
        if (string.IsNullOrEmpty(_currentUserId)) return;
        try
        {
            await ConnectionService.SendConnectionRequestAsync(_currentUserId, user.UserId);
            Snackbar.Add($"Connection request sent to {user.DisplayName}", Severity.Success);
            user.ExistingConnectionStatus = ConnectionStatus.Pending;
            user.IsRequestSentByCurrentUser = true;
            await LoadConnections();
        }
        catch (Exception ex) { Snackbar.Add($"Error: {ex.Message}", Severity.Error); }
    }

    private async Task AcceptRequest(PlayerConnection request)
    {
        if (string.IsNullOrEmpty(_currentUserId)) return;
        try
        {
            await ConnectionService.AcceptConnectionRequestAsync(request.Id, _currentUserId);
            Snackbar.Add("Connection accepted!", Severity.Success);
            await LoadConnections();
        }
        catch (Exception ex) { Snackbar.Add($"Error: {ex.Message}", Severity.Error); }
    }

    private async Task AcceptFromSearch(UserSearchResult user)
    {
        if (string.IsNullOrEmpty(_currentUserId)) return;
        var pendingRequest = _pendingRequests.FirstOrDefault(r => r.RequestingUserId == user.UserId);
        if (pendingRequest != null)
        {
            await AcceptRequest(pendingRequest);
            user.ExistingConnectionStatus = ConnectionStatus.Accepted;
        }
    }

    private async Task DeclineRequest(PlayerConnection request)
    {
        if (string.IsNullOrEmpty(_currentUserId)) return;
        try
        {
            await ConnectionService.DeclineConnectionRequestAsync(request.Id, _currentUserId);
            Snackbar.Add("Request declined.", Severity.Info);
            await LoadConnections();
        }
        catch (Exception ex) { Snackbar.Add($"Error: {ex.Message}", Severity.Error); }
    }

    private async Task CancelRequest(PlayerConnection request)
    {
        if (string.IsNullOrEmpty(_currentUserId)) return;
        try
        {
            await ConnectionService.CancelConnectionRequestAsync(request.Id, _currentUserId);
            Snackbar.Add("Request cancelled.", Severity.Info);
            await LoadConnections();
        }
        catch (Exception ex) { Snackbar.Add($"Error: {ex.Message}", Severity.Error); }
    }

    private async Task RemoveConnection(PlayerConnection connection)
    {
        if (string.IsNullOrEmpty(_currentUserId)) return;
        var parameters = new DialogParameters<ConfirmDialog>
        {
            { nameof(ConfirmDialog.ContentText), "Are you sure you want to remove this connection?" },
            { nameof(ConfirmDialog.ButtonText), "Remove" },
            { nameof(ConfirmDialog.Color), Color.Error }
        };
        var dialog = await DialogService.ShowAsync<ConfirmDialog>("Confirm Remove", parameters);
        var result = await dialog.Result;
        if (result is not null && !result.Canceled && result.Data is true)
        {
            try
            {
                await ConnectionService.RemoveConnectionAsync(connection.Id, _currentUserId);
                Snackbar.Add("Connection removed.", Severity.Info);
                await LoadConnections();
            }
            catch (Exception ex) { Snackbar.Add($"Error: {ex.Message}", Severity.Error); }
        }
    }

    // ── Managed Player Actions ──
    private void GoToAddPlayerPage() => NavigationManager.NavigateTo("/players/add");
    private void EditPlayer(int playerId) => NavigationManager.NavigateTo($"/players/edit/{playerId}");

    private async Task ViewConnectedPlayerReport(string userId)
    {
        var player = await PlayerService.GetPlayerByApplicationUserIdAsync(userId);
        if (player != null) NavigationManager.NavigateTo($"/players/{player.PlayerId}/report");
        else Snackbar.Add("This user does not have a player profile yet.", Severity.Warning);
    }

    private async Task PrepareDeletePlayer(Player player)
    {
        var parameters = new DialogParameters<ConfirmDialog>
        {
            { nameof(ConfirmDialog.ContentText), $"Are you sure you want to delete {player.FirstName} {player.LastName}? This cannot be undone." },
            { nameof(ConfirmDialog.ButtonText), "Delete" },
            { nameof(ConfirmDialog.Color), Color.Error }
        };
        var dialog = await DialogService.ShowAsync<ConfirmDialog>("Confirm Delete", parameters);
        var result = await dialog.Result;
        if (result is not null && !result.Canceled && result.Data is true)
        {
            try
            {
                bool deleted = await PlayerService.DeletePlayerAsync(player.PlayerId);
                if (deleted) { Snackbar.Add("Player deleted.", Severity.Success); await LoadManagedPlayers(); }
                else Snackbar.Add("Failed to delete player.", Severity.Warning);
            }
            catch (Exception ex) { Snackbar.Add($"Error: {ex.Message}", Severity.Error); }
        }
    }

    // ── Merge Actions ──
    private async Task OpenMergeDialog(string? targetUserId, string? targetUserName)
    {
        if (string.IsNullOrEmpty(_currentUserId) || string.IsNullOrEmpty(targetUserId)) return;
        try
        {
            var mergeablePlayers = await MergeService.GetMergeablePlayersAsync(_currentUserId, targetUserId);
            if (!mergeablePlayers.Any()) { Snackbar.Add("No managed players available to transfer.", Severity.Info); return; }

            var parameters = new DialogParameters<MergePlayerDialog>
            {
                { nameof(MergePlayerDialog.MergeablePlayers), mergeablePlayers },
                { nameof(MergePlayerDialog.TargetUserName), targetUserName ?? "Unknown" },
                { nameof(MergePlayerDialog.TargetUserId), targetUserId }
            };
            var options = new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true };
            var dialog = await DialogService.ShowAsync<MergePlayerDialog>("Transfer Player Data", parameters, options);
            var result = await dialog.Result;
            if (result is not null && !result.Canceled && result.Data is MergePlayerDialogResult mergeResult)
                await SendMergeRequest(mergeResult.SelectedPlayerId, targetUserId, mergeResult.Message);
        }
        catch (Exception ex) { Snackbar.Add($"Error: {ex.Message}", Severity.Error); }
    }

    private async Task SendMergeRequest(int sourcePlayerId, string targetUserId, string? message)
    {
        if (string.IsNullOrEmpty(_currentUserId)) return;
        try
        {
            await MergeService.RequestMergeAsync(_currentUserId, sourcePlayerId, targetUserId, message);
            Snackbar.Add("Data transfer request sent!", Severity.Success);
            await LoadMergeRequests();
        }
        catch (Exception ex) { Snackbar.Add($"Error: {ex.Message}", Severity.Error); }
    }

    private async Task AcceptMergeRequest(PlayerMergeRequest request)
    {
        if (string.IsNullOrEmpty(_currentUserId)) return;
        try
        {
            var result = await MergeService.AcceptMergeRequestAsync(request.Id, _currentUserId);
            if (result != null)
            {
                var skippedText = result.RoundsSkipped > 0 ? $" ({result.RoundsSkipped} skipped duplicates)" : "";
                Snackbar.Add($"Data transferred! {result.RoundsMerged} rounds merged{skippedText}.", Severity.Success);
                await LoadMergeRequests();
                await LoadManagedPlayers();
            }
        }
        catch (Exception ex) { Snackbar.Add($"Error: {ex.Message}", Severity.Error); }
    }

    private async Task DeclineMergeRequest(PlayerMergeRequest request)
    {
        if (string.IsNullOrEmpty(_currentUserId)) return;
        try
        {
            await MergeService.DeclineMergeRequestAsync(request.Id, _currentUserId);
            Snackbar.Add("Transfer request declined.", Severity.Info);
            await LoadMergeRequests();
        }
        catch (Exception ex) { Snackbar.Add($"Error: {ex.Message}", Severity.Error); }
    }

    public void Dispose()
    {
        _searchDebounceTimer?.Stop();
        _searchDebounceTimer?.Dispose();
    }
}
