@page "/players/{PlayerId:int}/profile"
@page "/profile"
@attribute [Authorize]
@inject IPlayerService PlayerService
@inject IRoundService RoundService
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject NavigationManager NavigationManager

@using GolfTrackerApp.Core.Models
@using GolfTrackerApp.Core.Services
@using GolfTrackerApp.Web.Components.Pages.Handicaps
@using Microsoft.AspNetCore.Authorization
@using System.Security.Claims

@rendermode InteractiveServer

<PageTitle>@(_player is null ? "Profile" : $"{_player.FirstName} {_player.LastName}")</PageTitle>

@if (_loading)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
}
else if (_resolvedPlayerId is null)
{
    <MudAlert Severity="Severity.Info">
        Your account is not linked to a player profile yet.
    </MudAlert>
}
else if (_player is null)
{
    <MudAlert Severity="Severity.Error">Player not found.</MudAlert>
}
else
{
    <div class="d-flex align-center justify-space-between mb-4">
        <div>
            <MudText Typo="Typo.h4">@_player.FirstName @_player.LastName</MudText>
            @if (_player.Handicap is double hcp)
            {
                <MudText Typo="Typo.subtitle1" Color="Color.Secondary">Handicap @hcp.ToString("0.0")</MudText>
            }
        </div>
        <MudButton Variant="Variant.Filled" Color="Color.Success" StartIcon="@Icons.Material.Filled.AddCircle"
                   Href="rounds/record">Record Round</MudButton>
    </div>

    <MudTabs Elevation="0" Rounded="true" ApplyEffectsToContainer="true" PanelClass="pt-4">
        <MudTabPanel Text="Overview" Icon="@Icons.Material.Filled.Person">
            <MudGrid Class="mb-2">
                <MudItem xs="6" md="3">
                    <MudPaper Class="pa-4" Outlined="true">
                        <MudText Typo="Typo.overline">Handicap</MudText>
                        <MudText Typo="Typo.h4">@(_player.Handicap is double h ? h.ToString("0.0") : "—")</MudText>
                    </MudPaper>
                </MudItem>
                <MudItem xs="6" md="3">
                    <MudPaper Class="pa-4" Outlined="true">
                        <MudText Typo="Typo.overline">Rounds</MudText>
                        <MudText Typo="Typo.h4">@_roundCount</MudText>
                    </MudPaper>
                </MudItem>
                <MudItem xs="6" md="3">
                    <MudPaper Class="pa-4" Outlined="true">
                        <MudText Typo="Typo.overline">Last played</MudText>
                        <MudText Typo="Typo.h6" Class="mt-1">
                            @(_rounds.FirstOrDefault()?.DatePlayed.ToString("d MMM yyyy") ?? "—")
                        </MudText>
                    </MudPaper>
                </MudItem>
            </MudGrid>

            <MudText Typo="Typo.h6" Class="mb-2">Recent rounds</MudText>
            @if (!_rounds.Any())
            {
                <MudText Typo="Typo.body2" Color="Color.Secondary">
                    No rounds yet. Record your first round to start tracking your game.
                </MudText>
            }
            else
            {
                <MudTable Items="@_recentRounds" Dense="true" Hover="true">
                    <HeaderContent>
                        <MudTh>Date</MudTh>
                        <MudTh>Course</MudTh>
                        <MudTh Style="text-align:right">Holes</MudTh>
                        <MudTh></MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd DataLabel="Date">@context.DatePlayed.ToString("d MMM yyyy")</MudTd>
                        <MudTd DataLabel="Course">@CourseLabel(context.GolfCourse)</MudTd>
                        <MudTd DataLabel="Holes" Style="text-align:right">@context.HolesPlayed</MudTd>
                        <MudTd Style="text-align:right">
                            <MudButton Size="Size.Small" Variant="Variant.Text" Href="@($"rounds/{context.RoundId}")">View</MudButton>
                        </MudTd>
                    </RowTemplate>
                </MudTable>
            }
        </MudTabPanel>

        <MudTabPanel Text="Stats" Icon="@Icons.Material.Filled.BarChart">
            <PlayerReport PlayerId="_resolvedPlayerId.Value" Embedded="true" />
        </MudTabPanel>

        <MudTabPanel Text="Handicap" Icon="@Icons.Material.Filled.TrendingDown">
            <HandicapPanel PlayerId="_resolvedPlayerId.Value" />
        </MudTabPanel>

        <MudTabPanel Text="Rounds" Icon="@Icons.Material.Filled.GolfCourse">
            @if (!_rounds.Any())
            {
                <MudText Typo="Typo.body2" Color="Color.Secondary">No rounds recorded yet.</MudText>
            }
            else
            {
                <MudTable Items="@_rounds" Dense="true" Hover="true">
                    <HeaderContent>
                        <MudTh>Date</MudTh>
                        <MudTh>Course</MudTh>
                        <MudTh Style="text-align:right">Holes</MudTh>
                        <MudTh></MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd DataLabel="Date">@context.DatePlayed.ToString("d MMM yyyy")</MudTd>
                        <MudTd DataLabel="Course">@CourseLabel(context.GolfCourse)</MudTd>
                        <MudTd DataLabel="Holes" Style="text-align:right">@context.HolesPlayed</MudTd>
                        <MudTd Style="text-align:right">
                            <MudButton Size="Size.Small" Variant="Variant.Text"
                                       Href="@($"rounds/{context.RoundId}")">View</MudButton>
                        </MudTd>
                    </RowTemplate>
                </MudTable>
            }
        </MudTabPanel>
    </MudTabs>
}

@code {
    [Parameter] public int? PlayerId { get; set; }

    private bool _loading = true;
    private int? _resolvedPlayerId;
    private Player? _player;
    private List<Round> _rounds = new();
    private List<Round> _recentRounds = new();
    private int _roundCount;

    private static string CourseLabel(GolfCourse? course) =>
        course is null ? "" :
        string.IsNullOrWhiteSpace(course.GolfClub?.Name) ? course.Name : $"{course.GolfClub!.Name} - {course.Name}";

    protected override async Task OnParametersSetAsync()
    {
        _loading = true;

        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        var userId = user.FindFirstValue(ClaimTypes.NameIdentifier);
        var isAdmin = user.IsInRole("Admin");

        // /profile resolves to the current user's own player; /players/{id}/profile is explicit.
        _resolvedPlayerId = PlayerId
            ?? (userId is not null ? (await PlayerService.GetPlayerByApplicationUserIdAsync(userId))?.PlayerId : null);

        if (_resolvedPlayerId is int playerId && userId is not null)
        {
            _player = await PlayerService.GetPlayerByIdAsync(playerId);
            _rounds = await RoundService.GetRoundsForPlayerAsync(playerId, userId, isAdmin);
            _roundCount = _rounds.Count;
            _recentRounds = _rounds.Take(5).ToList();
        }

        _loading = false;
    }
}
