@page "/admin/ai-providers"
@attribute [Authorize(Roles = "Admin")]

@using GolfTrackerApp.Web.Models
@using GolfTrackerApp.Web.Services
@using Microsoft.AspNetCore.Authorization
@using System.Security.Claims

@inject IAiProviderSettingsService ProviderSettingsService
@inject IConfiguration Configuration
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject ILogger<AiProviders> Logger

@rendermode InteractiveServer

<PageTitle>AI Provider Management</PageTitle>

<MudText Typo="Typo.h4" Class="mb-4">
    <MudIcon Icon="@Icons.Material.Filled.SmartToy" Class="mr-2" />
    AI Provider Management
</MudText>

@if (loading)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
}
else if (providerViewModels.Any())
{
    <MudText Typo="Typo.body2" Color="Color.Tertiary" Class="mb-3">
        Use the arrows to reorder failover priority. The first enabled provider with an API key will be used.
    </MudText>

    <div class="d-flex flex-column gap-2 mb-4">
        @for (int i = 0; i < providerViewModels.Count; i++)
        {
            var index = i;
            var vm = providerViewModels[index];
            <MudPaper Elevation="2" Class="pa-3 d-flex align-center gap-3">
                <MudText Typo="Typo.body2" Color="Color.Tertiary" Style="min-width: 24px; text-align: center;">@(index + 1)</MudText>
                <MudButtonGroup OverrideStyles="false" Size="Size.Small" Variant="Variant.Outlined">
                    <MudIconButton Icon="@Icons.Material.Filled.KeyboardArrowUp"
                                   Size="Size.Small"
                                   Disabled="@(index == 0)"
                                   OnClick="@(() => MoveProvider(index, -1))" />
                    <MudIconButton Icon="@Icons.Material.Filled.KeyboardArrowDown"
                                   Size="Size.Small"
                                   Disabled="@(index == providerViewModels.Count - 1)"
                                   OnClick="@(() => MoveProvider(index, 1))" />
                </MudButtonGroup>
                <MudText Typo="Typo.body1" Style="min-width: 120px;"><strong>@vm.ProviderName</strong></MudText>
                <MudText Typo="Typo.body2" Color="Color.Tertiary" Style="min-width: 160px;">@vm.Model</MudText>
                @if (vm.HasApiKey)
                {
                    <MudChip T="string" Color="Color.Success" Size="Size.Small">API Key</MudChip>
                }
                else
                {
                    <MudChip T="string" Color="Color.Error" Size="Size.Small">No Key</MudChip>
                }
                <MudSwitch T="bool" Value="vm.Enabled" Color="Color.Primary"
                           Disabled="@(!vm.HasApiKey)"
                           ValueChanged="@(async (bool val) => await ToggleEnabled(vm, val))"
                           Class="ml-auto" />
                <MudText Typo="Typo.caption" Color="Color.Tertiary" Style="min-width: 130px;">
                    @vm.UpdatedAt.ToString("dd MMM yyyy HH:mm")
                </MudText>
            </MudPaper>
        }
    </div>

    @if (!string.IsNullOrEmpty(statusMessage))
    {
        <MudAlert Severity="@statusSeverity" Class="mt-2" Dense="true">@statusMessage</MudAlert>
    }

    <MudText Typo="Typo.caption" Color="Color.Tertiary" Class="mt-4">
        API keys are managed via user-secrets or environment variables. Models and endpoints are configured in appsettings.json.
    </MudText>
}
else
{
    <MudAlert Severity="Severity.Info">No AI providers configured. Check appsettings.json for provider entries.</MudAlert>
}

@code {
    private List<ProviderViewModel> providerViewModels = new();
    private bool loading = true;
    private string? statusMessage;
    private Severity statusSeverity = Severity.Success;

    protected override async Task OnInitializedAsync()
    {
        await LoadProviders();
        loading = false;
    }

    private async Task LoadProviders()
    {
        var dbSettings = await ProviderSettingsService.GetAllAsync();
        var providersSection = Configuration.GetSection("AiInsights:Providers");

        providerViewModels = dbSettings.Select(db =>
        {
            var configSection = providersSection.GetSection(db.ProviderName);
            return new ProviderViewModel
            {
                AiProviderSettingsId = db.AiProviderSettingsId,
                ProviderName = db.ProviderName,
                Enabled = db.Enabled,
                Priority = db.Priority,
                UpdatedAt = db.UpdatedAt,
                Model = configSection?.GetValue<string>("Model") ?? "",
                HasApiKey = !string.IsNullOrEmpty(configSection?.GetValue<string>("ApiKey"))
            };
        }).OrderBy(p => p.Priority).ToList();
    }

    private async Task MoveProvider(int currentIndex, int direction)
    {
        var targetIndex = currentIndex + direction;
        if (targetIndex < 0 || targetIndex >= providerViewModels.Count) return;

        // Swap the two items
        (providerViewModels[currentIndex], providerViewModels[targetIndex]) =
            (providerViewModels[targetIndex], providerViewModels[currentIndex]);

        // Reassign priorities based on new order
        for (int i = 0; i < providerViewModels.Count; i++)
        {
            providerViewModels[i].Priority = i + 1;
        }

        await SaveAllPriorities();
    }

    private async Task SaveAllPriorities()
    {
        try
        {
            var userId = await GetUserIdAsync();
            var priorities = providerViewModels
                .Select(p => (p.AiProviderSettingsId, p.Priority))
                .ToList();

            await ProviderSettingsService.UpdatePrioritiesAsync(priorities, userId);

            foreach (var vm in providerViewModels)
                vm.UpdatedAt = DateTime.UtcNow;

            statusMessage = "Provider order saved.";
            statusSeverity = Severity.Success;
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to save provider priorities");
            statusMessage = "Failed to save provider order.";
            statusSeverity = Severity.Error;
        }

        StateHasChanged();
    }

    private async Task ToggleEnabled(ProviderViewModel vm, bool enabled)
    {
        vm.Enabled = enabled;
        try
        {
            var userId = await GetUserIdAsync();
            await ProviderSettingsService.UpdateAsync(new AiProviderSettings
            {
                AiProviderSettingsId = vm.AiProviderSettingsId,
                ProviderName = vm.ProviderName,
                Enabled = vm.Enabled,
                Priority = vm.Priority
            }, userId);

            vm.UpdatedAt = DateTime.UtcNow;
            statusMessage = $"{vm.ProviderName} {(enabled ? "enabled" : "disabled")}.";
            statusSeverity = Severity.Success;
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to toggle provider {Provider}", vm.ProviderName);
            vm.Enabled = !enabled; // revert
            statusMessage = $"Failed to update {vm.ProviderName}.";
            statusSeverity = Severity.Error;
        }

        StateHasChanged();
    }

    private async Task<string> GetUserIdAsync()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        return authState.User.FindFirstValue(ClaimTypes.NameIdentifier) ?? "";
    }

    private class ProviderViewModel
    {
        public int AiProviderSettingsId { get; set; }
        public string ProviderName { get; set; } = string.Empty;
        public bool Enabled { get; set; }
        public int Priority { get; set; }
        public DateTime UpdatedAt { get; set; }
        public string Model { get; set; } = string.Empty;
        public bool HasApiKey { get; set; }
    }
}
