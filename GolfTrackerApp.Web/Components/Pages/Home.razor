            </section>

            <!-- Recent Clubs Section -->
            @if (recentGolfClubs is not null && recentGolfClubs.Any())
            {
                <section class="gp-section gp-section-light">
                    <MudContainer MaxWidth="MaxWidth.Large">
                        <div class="gp-section-header">
                            <h2 class="gp-section-title">Explore Our Course Database</h2>
                            <p class="gp-section-subtitle">Browse golf clubs and courses from around the world</p>
                        </div>
                        <MudGrid Spacing="3">
                            @foreach (var club in recentGolfClubs.Take(4))
