<style>
    /* Page-specific loading state */
    .gp-loading-container {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        min-height: 60vh;
    }
</style>

@code {
    private bool isLoading = true;
    private bool isAuthenticated = false;
    private int _currentPlayerId;

    // Data for authenticated dashboard
    private DashboardStats dashboardStats = new();
    private List<PlayingPartnerSummary>? partnerSummary;
    private List<ChartSeries> _performanceSeries = new();
    private string[] _performanceXAxisLabels = Array.Empty<string>();
    private List<Round>? recentRounds;
    private List<CourseHistoryItem>? _courseHistory;
    private ScoringDistribution? _scoringDistribution;
    private PerformanceByPar? _performanceByPar;

    // AI Insights
    private bool aiInsightEnabled;
    private bool aiLoading;
    private AiInsightResult? aiInsight;

    // Data for public landing page
    private int totalGolfClubs = 0;
    private int totalGolfCourses = 0;
    private int uniqueCountries = 0;
    private List<GolfClub>? recentGolfClubs;

    // Chart configuration
    private ChartOptions _chartOptions = new()
    {
        YAxisTicks = 5,
        MaxNumYAxisTicks = 5,
        YAxisLines = true,
        XAxisLines = false,
        LineStrokeWidth = 3
    };

    private AxisChartOptions _axisChartOptions = new()
    {
        MatchBoundsToSize = true
    };

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        isAuthenticated = user.Identity?.IsAuthenticated ?? false;
        var currentUserId = user.FindFirstValue(ClaimTypes.NameIdentifier);

        if (isAuthenticated && currentUserId is not null)
        {
            // Load authenticated user dashboard data
            var player = await PlayerService.GetPlayerByApplicationUserIdAsync(currentUserId);
            if (player is not null)
            {
                _currentPlayerId = player.PlayerId;
                var isAdmin = user.IsInRole("Admin");

                // Load data for all cards in parallel for efficiency
                var dashboardStatsTask = ReportService.GetDashboardStatsAsync(currentUserId);
                var partnerTask = ReportService.GetPlayingPartnerSummaryAsync(currentUserId, 5);
                var performanceTask = ReportService.GetPlayerPerformanceSummaryAsync(currentUserId, 10);
                var recentRoundsTask = RoundService.GetRecentRoundsAsync(currentUserId, isAdmin, 5);
                var courseHistoryTask = ReportService.GetCourseHistoryAsync(currentUserId, 6);
                var scoringDistTask = ReportService.GetScoringDistributionAsync(player.PlayerId, null, null, null, null, null);
                var parPerfTask = ReportService.GetPerformanceByParAsync(player.PlayerId, null, null, null, null, null);

                await Task.WhenAll(dashboardStatsTask, partnerTask, performanceTask, recentRoundsTask, courseHistoryTask, scoringDistTask, parPerfTask);

                dashboardStats = dashboardStatsTask.Result;
                partnerSummary = partnerTask.Result;
                PreparePerformanceChart(performanceTask.Result);
                recentRounds = recentRoundsTask.Result;
                _courseHistory = courseHistoryTask.Result;
                _scoringDistribution = scoringDistTask.Result;
                _performanceByPar = parPerfTask.Result;

                // Fire-and-forget AI insights load (don't block dashboard render)
                aiInsightEnabled = Configuration.GetValue<bool>("AiInsights:Enabled");
                if (aiInsightEnabled && dashboardStats?.TotalRounds > 0)
                {
                    _ = LoadAiInsights(currentUserId);
                }
            }
        }
        else
        {
            // Load public landing page data
            await LoadPublicLandingPageData();
        }
        
        isLoading = false;
    }

    private async Task LoadPublicLandingPageData()
    {
        try
        {
            var allClubs = await GolfClubService.GetAllGolfClubsAsync();
            var allCourses = await GolfCourseService.GetAllGolfCoursesAsync();

            totalGolfClubs = allClubs.Count;
            totalGolfCourses = allCourses.Count;
            uniqueCountries = allClubs
                .Where(c => !string.IsNullOrWhiteSpace(c.Country))
                .Select(c => c.Country)
                .Distinct()
                .Count();

            // Group courses by club for the display
            var coursesByClub = allCourses.GroupBy(c => c.GolfClubId)
                .ToDictionary(g => g.Key, g => g.ToList());

            // Assign courses to clubs for display
            foreach (var club in allClubs)
            {
                if (coursesByClub.TryGetValue(club.GolfClubId, out var courses))
                {
                    club.GolfCourses = courses;
                }
                else
                {
                    club.GolfCourses = new List<GolfCourse>();
                }
            }

            recentGolfClubs = allClubs
                .OrderBy(c => c.Name)
                .Take(6)
                .ToList();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading public landing page data: {ex.Message}");
            totalGolfClubs = 0;
            totalGolfCourses = 0;
            uniqueCountries = 0;
            recentGolfClubs = new List<GolfClub>();
        }
    }

    private void PreparePerformanceChart(List<PlayerPerformanceDataPoint> data)
    {
        if (data is null || !data.Any()) return;

        _performanceSeries = new List<ChartSeries>
        {
            new ChartSeries { Name = "Score vs Par", Data = data.Select(d => (double)d.ScoreVsPar).ToArray() }
        };
        _performanceXAxisLabels = data.Select(d => d.Date.ToString("MMM dd")).ToArray();
    }

    private async Task LoadAiInsights(string userId)
    {
        aiLoading = true;
        StateHasChanged();
        try
        {
            aiInsight = await AiInsightService.GetDashboardInsightsAsync(userId);
        }
        catch (Exception ex)
        {
            aiInsight = new AiInsightResult
            {
                Success = false,
                ErrorMessage = "Could not load AI insights."
            };
        }
        finally
        {
            aiLoading = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task RefreshAiInsights()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var userId = authState.User.FindFirstValue(ClaimTypes.NameIdentifier);
        if (userId != null)
        {
            await LoadAiInsights(userId);
        }
    }
}
