@page "/"
@rendermode InteractiveServer

@inject AuthenticationStateProvider AuthenticationStateProvider
@inject IRoundService RoundService
@inject IReportService ReportService
@inject IPlayerService PlayerService
@inject IGolfClubService GolfClubService
@inject IGolfCourseService GolfCourseService
@inject NavigationManager NavigationManager
@inject ISnackbar Snackbar
@inject IDialogService DialogService

@using System.Security.Claims
@using GolfTrackerApp.Web.Models
@using GolfTrackerApp.Web.Components.Shared
@using GolfTrackerApp.Web.Services
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using MudBlazor

<PageTitle>@(isAuthenticated ? "Golf Dashboard" : "Golf Tracker - Track Your Game Like a Pro")</PageTitle>

<AuthorizeView>
    <Authorized>
        <!-- ================================================================
             PREMIUM AUTHENTICATED DASHBOARD
             ================================================================ -->
        <div class="gp-dashboard">
            @if (isLoading)
            {
                <div class="gp-loading-container">
                    <MudProgressCircular Color="Color.Primary" Size="Size.Large" Indeterminate="true" />
                    <MudText Typo="Typo.body1" Class="mt-4" Color="Color.Secondary">Loading your dashboard...</MudText>
                </div>
            }
            else
            {
                <!-- Dashboard Header -->
                <div class="gp-dashboard-header gp-animate-fade-in-up">
                    <div class="d-flex justify-space-between align-center flex-wrap gap-4">
                        <div>
                            <MudText Typo="Typo.h4" Class="gp-dashboard-title">Welcome back! 👋</MudText>
                            <MudText Typo="Typo.body1" Class="gp-dashboard-subtitle">Track your progress and celebrate your achievements</MudText>
                        </div>
                        <MudButton Href="/rounds/record"
                                   Variant="Variant.Filled"
                                   Color="Color.Primary"
                                   Size="Size.Large"
                                   StartIcon="@Icons.Material.Filled.Add"
                                   Class="gp-btn-hero">
                            Record Round
                        </MudButton>
                    </div>
                </div>

                @if (dashboardStats.TotalRounds == 0)
                {
                    <!-- Empty State - First Time User -->
                    <MudPaper Class="pa-8 text-center gp-card gp-animate-fade-in-up" Elevation="0">
                        <div class="gp-feature-icon mx-auto mb-6">🏌️</div>
                        <MudText Typo="Typo.h5" Class="mb-3">Ready to start your golf journey?</MudText>
                        <MudText Typo="Typo.body1" Color="Color.Secondary" Class="mb-6" Style="max-width: 500px; margin: 0 auto;">
                            Record your first round to unlock performance analytics, track your improvement, and compete with friends.
                        </MudText>
                        <MudButton Href="/rounds/record"
                                   Variant="Variant.Filled"
                                   Color="Color.Primary"
                                   Size="Size.Large"
                                   StartIcon="@Icons.Material.Filled.PlayArrow"
                                   Class="gp-btn-large">
                            Record Your First Round
                        </MudButton>
                    </MudPaper>
                }
                else
                {
                    <!-- Stats Cards Grid -->
                    <MudGrid Spacing="4" Class="mb-6">
                        <MudItem xs="6" sm="6" md="3">
                            <div class="gp-stat-card gp-animate-fade-in-up gp-animate-stagger-1">
                                <div class="gp-stat-icon">🏌️</div>
                                <div class="gp-stat-value">@dashboardStats.TotalRounds</div>
                                <div class="gp-stat-label">Rounds Played</div>
                                @if (dashboardStats.LastRoundDate.HasValue)
                                {
                                    <div class="gp-stat-trend gp-stat-trend-neutral">
                                        📅 @dashboardStats.LastRoundDate.Value.ToString("MMM dd")
                                    </div>
                                }
                            </div>
                        </MudItem>
                        <MudItem xs="6" sm="6" md="3">
                            <div class="gp-stat-card gp-animate-fade-in-up gp-animate-stagger-2">
                                <div class="gp-stat-icon">🏆</div>
                                <div class="gp-stat-value">@(dashboardStats.BestScore?.ToString() ?? "—")</div>
                                <div class="gp-stat-label">Best Score</div>
                                @if (dashboardStats.LowestToPar.HasValue)
                                {
                                    <div class="gp-stat-trend @(dashboardStats.LowestToPar.Value <= 0 ? "gp-stat-trend-up" : "gp-stat-trend-down")">
                                        @(dashboardStats.LowestToPar.Value >= 0 ? "+" : "")@dashboardStats.LowestToPar.Value to par
                                    </div>
                                }
                            </div>
                        </MudItem>
                        <MudItem xs="6" sm="6" md="3">
                            <div class="gp-stat-card gp-animate-fade-in-up gp-animate-stagger-3">
                                <div class="gp-stat-icon">📊</div>
                                <div class="gp-stat-value">@(dashboardStats.AverageToPar?.ToString("+0.0;-0.0;E") ?? "—")</div>
                                <div class="gp-stat-label">Avg. to Par</div>
                                @if (dashboardStats.IsImprovingStreak)
                                {
                                    <div class="gp-stat-trend gp-stat-trend-up">
                                        ↗️ Improving
                                    </div>
                                }
                            </div>
                        </MudItem>
                        <MudItem xs="6" sm="6" md="3">
                            <div class="gp-stat-card gp-animate-fade-in-up gp-animate-stagger-4">
                                <div class="gp-stat-icon">⭐</div>
                                <div class="gp-stat-value">@dashboardStats.FavoriteCourseRounds</div>
                                <div class="gp-stat-label">Most Played</div>
                                @if (!string.IsNullOrEmpty(dashboardStats.FavoriteCourseName))
                                {
                                    <div class="gp-stat-trend gp-stat-trend-neutral" title="@dashboardStats.FavoriteCourseName">
                                        @(dashboardStats.FavoriteCourseName.Length > 18 ? 
                                          dashboardStats.FavoriteCourseName[..18] + "..." : 
                                          dashboardStats.FavoriteCourseName)
                                    </div>
                                }
                            </div>
                        </MudItem>
                    </MudGrid>

                    <!-- Main Dashboard Grid -->
                    <MudGrid Spacing="4">
                        <!-- Quick Actions Card -->
                        <MudItem xs="12" md="4">
                            <MudCard Class="gp-card h-100 gp-animate-fade-in-up gp-animate-stagger-2" Elevation="0">
                                <MudCardHeader>
                                    <CardHeaderContent>
                                        <MudText Typo="Typo.h6">⚡ Quick Actions</MudText>
                                    </CardHeaderContent>
                                </MudCardHeader>
                                <MudCardContent Class="d-flex flex-column gap-3">
                                    <MudButton Href="/rounds/record"
                                               Variant="Variant.Outlined"
                                               Color="Color.Primary"
                                               FullWidth="true"
                                               StartIcon="@Icons.Material.Filled.Edit"
                                               Class="justify-start">
                                        Record a Round
                                    </MudButton>
                                    <MudButton Variant="Variant.Outlined"
                                               FullWidth="true"
                                               StartIcon="@Icons.Material.Filled.FiberManualRecord"
                                               Disabled="true"
                                               Class="justify-start">
                                        Live Scoring (Coming Soon)
                                    </MudButton>
                                    <MudButton Href="@($"/players/{_currentPlayerId}/report")"
                                               Variant="Variant.Outlined"
                                               Color="Color.Primary"
                                               FullWidth="true"
                                               StartIcon="@Icons.Material.Filled.Analytics"
                                               Class="justify-start">
                                        View Full Report
                                    </MudButton>
                                    <MudButton Href="/golfclubs"
                                               Variant="Variant.Outlined"
                                               Color="Color.Primary"
                                               FullWidth="true"
                                               StartIcon="@Icons.Material.Filled.Explore"
                                               Class="justify-start">
                                        Explore Courses
                                    </MudButton>
                                </MudCardContent>
                            </MudCard>
                        </MudItem>

                        <!-- Performance Chart -->
                        <MudItem xs="12" md="8">
                            <MudCard Class="gp-card h-100 gp-animate-fade-in-up gp-animate-stagger-3" Elevation="0">
                                <MudCardHeader>
                                    <CardHeaderContent>
                                        <MudText Typo="Typo.h6">📈 Recent Performance</MudText>
                                    </CardHeaderContent>
                                    <CardHeaderActions>
                                        <MudIconButton Icon="@Icons.Material.Filled.OpenInNew" 
                                                       Color="Color.Primary" 
                                                       Href="@($"/players/{_currentPlayerId}/report")"
                                                       Size="Size.Small" />
                                    </CardHeaderActions>
                                </MudCardHeader>
                                <MudCardContent Class="pa-4">
                                    @if (_performanceSeries is not null && _performanceSeries.Any())
                                    {
                                        <MudChart ChartType="ChartType.Line" 
                                                 ChartSeries="@_performanceSeries" 
                                                 XAxisLabels="@_performanceXAxisLabels" 
                                                 Width="100%" 
                                                 Height="280px"
                                                 ChartOptions="@_chartOptions"
                                                 AxisChartOptions="@_axisChartOptions" />
                                    }
                                    else
                                    {
                                        <div class="text-center pa-8">
                                            <MudIcon Icon="@Icons.Material.Filled.Timeline" Size="Size.Large" Color="Color.Secondary" Class="mb-3" />
                                            <MudText Color="Color.Secondary">Play a few rounds to see your trends</MudText>
                                        </div>
                                    }
                                </MudCardContent>
                            </MudCard>
                        </MudItem>

                        <!-- Recent Rounds -->
                        <MudItem xs="12" md="6">
                            <MudCard Class="gp-card h-100 gp-animate-fade-in-up gp-animate-stagger-4" Elevation="0">
                                <MudCardHeader>
                                    <CardHeaderContent>
                                        <MudText Typo="Typo.h6">🏌️ Recent Rounds</MudText>
                                    </CardHeaderContent>
                                    <CardHeaderActions>
                                        <MudIconButton Icon="@Icons.Material.Filled.List" 
                                                       Color="Color.Primary" 
                                                       Href="/rounds"
                                                       Size="Size.Small" />
                                    </CardHeaderActions>
                                </MudCardHeader>
                                <MudCardContent Class="pa-0">
                                    @if (recentRounds is null || !recentRounds.Any())
                                    {
                                        <div class="text-center pa-8">
                                            <MudIcon Icon="@Icons.Material.Filled.GolfCourse" Size="Size.Large" Color="Color.Secondary" Class="mb-3" />
                                            <MudText Color="Color.Secondary">No rounds recorded yet</MudText>
                                        </div>
                                    }
                                    else
                                    {
                                        <MudList T="Round" Dense="true">
                                            @foreach (var round in recentRounds.Take(5))
                                            {
                                                var totalScore = round.Scores.Where(s => s.PlayerId == _currentPlayerId).Sum(s => s.Strokes);
                                                var totalPar = round.Scores.Where(s => s.PlayerId == _currentPlayerId && s.Hole != null).Sum(s => s.Hole!.Par);
                                                var toPar = totalScore - totalPar;
                                                
                                                <MudListItem T="Round" OnClick="@(() => NavigationManager.NavigateTo($"/rounds/{round.RoundId}"))">
                                                    <div class="d-flex justify-space-between align-center w-100">
                                                        <div>
                                                            <MudText Typo="Typo.body2" Class="font-weight-medium">@round.GolfCourse?.Name</MudText>
                                                            <MudText Typo="Typo.caption" Color="Color.Secondary">@round.DatePlayed.ToString("MMM dd, yyyy")</MudText>
                                                        </div>
                                                        <div class="text-right">
                                                            <MudText Typo="Typo.body1" Class="font-weight-bold">@totalScore</MudText>
                                                            <MudChip T="string" Size="Size.Small" Color="@(toPar < 0 ? Color.Success : toPar > 0 ? Color.Warning : Color.Default)" Variant="Variant.Text">
                                                                @(toPar >= 0 ? "+" : "")@toPar
                                                            </MudChip>
                                                        </div>
                                                    </div>
                                                </MudListItem>
                                            }
                                        </MudList>
                                    }
                                </MudCardContent>
                            </MudCard>
                        </MudItem>

                        <!-- Playing Partners -->
                        <MudItem xs="12" md="6">
                            <MudCard Class="gp-card h-100 gp-animate-fade-in-up gp-animate-stagger-5" Elevation="0">
                                <MudCardHeader>
                                    <CardHeaderContent>
                                        <MudText Typo="Typo.h6">👥 Playing Partners</MudText>
                                    </CardHeaderContent>
                                    <CardHeaderActions>
                                        <MudIconButton Icon="@Icons.Material.Filled.People" 
                                                       Color="Color.Primary" 
                                                       Href="/players"
                                                       Size="Size.Small" />
                                    </CardHeaderActions>
                                </MudCardHeader>
                                <MudCardContent Class="pa-0">
                                    @if (partnerSummary is null || !partnerSummary.Any())
                                    {
                                        <div class="text-center pa-8">
                                            <MudIcon Icon="@Icons.Material.Filled.GroupAdd" Size="Size.Large" Color="Color.Secondary" Class="mb-3" />
                                            <MudText Color="Color.Secondary">Play with friends to track your rivalry!</MudText>
                                        </div>
                                    }
                                    else
                                    {
                                        <MudList T="PlayingPartnerSummary" Dense="true">
                                            @foreach (var partner in partnerSummary.Take(5))
                                            {
                                                <MudListItem T="PlayingPartnerSummary" Href="@($"/players/{partner.PartnerId}/report")">
                                                    <div class="d-flex justify-space-between align-center w-100">
                                                        <div>
                                                            <MudText Typo="Typo.body2" Class="font-weight-medium">@partner.PartnerName</MudText>
                                                            <MudText Typo="Typo.caption" Color="Color.Secondary">@(partner.UserWins + partner.PartnerWins + partner.Ties) rounds together</MudText>
                                                        </div>
                                                        <div class="text-right">
                                                            <MudText Typo="Typo.body2" Class="font-weight-bold" Color="@(partner.UserWins > partner.PartnerWins ? Color.Success : partner.UserWins < partner.PartnerWins ? Color.Error : Color.Default)">
                                                                @partner.UserWins-@partner.PartnerWins-@partner.Ties
                                                            </MudText>
                                                            <MudText Typo="Typo.caption" Color="Color.Secondary">
                                                                @(partner.UserWins > partner.PartnerWins ? "You lead" : 
                                                                  partner.UserWins < partner.PartnerWins ? "They lead" : "Tied")
                                                            </MudText>
                                                        </div>
                                                    </div>
                                                </MudListItem>
                                            }
                                        </MudList>
                                    }
                                </MudCardContent>
                            </MudCard>
                        </MudItem>
                    </MudGrid>
                }
            }
        </div>
    </Authorized>

    <NotAuthorized>
        <!-- ================================================================
             PREMIUM PUBLIC LANDING PAGE
             ================================================================ -->
        @if (isLoading)
        {
            <div class="gp-loading-container">
                <MudProgressCircular Color="Color.Primary" Size="Size.Large" Indeterminate="true" />
            </div>
        }
        else
        {
            <!-- Hero Section -->
            <section class="gp-hero">
                <div class="gp-hero-content">
                    <div class="gp-hero-badge">
                        ⛳ Free Forever • Track Unlimited Rounds
                    </div>
                    <h1 class="gp-hero-title">
                        Track Your Golf Game<br/>Like a Pro
                    </h1>
                    <p class="gp-hero-subtitle">
                        Join golfers worldwide who use Golf Tracker to record rounds, analyze performance, and continuously improve their game.
                    </p>
                    <div class="gp-hero-actions">
                        <MudButton Href="/Account/Register"
                                   Variant="Variant.Filled"
                                   Size="Size.Large"
                                   Class="gp-hero-btn-primary"
                                   StartIcon="@Icons.Material.Filled.PlayArrow">
                            Start Free Today
                        </MudButton>
                        <MudButton Href="/Account/Login"
                                   Variant="Variant.Outlined"
                                   Size="Size.Large"
                                   Class="gp-hero-btn-secondary"
                                   StartIcon="@Icons.Material.Filled.Login">
                            Sign In
                        </MudButton>
                    </div>
                </div>
            </section>

            <!-- Stats Section -->
            <section class="gp-section gp-section-light">
                <MudContainer MaxWidth="MaxWidth.Large">
                    <div class="gp-section-header">
                        <h2 class="gp-section-title">Our Growing Community</h2>
                        <p class="gp-section-subtitle">Join thousands of golfers already tracking their game</p>
                    </div>
                    <MudGrid Spacing="4" Justify="Justify.Center">
                        <MudItem xs="6" sm="3">
                            <div class="gp-stat-card text-center gp-animate-fade-in-up gp-animate-stagger-1">
                                <div class="gp-stat-value" style="color: var(--gp-primary-500);">@totalGolfClubs</div>
                                <div class="gp-stat-label">Golf Clubs</div>
                            </div>
                        </MudItem>
                        <MudItem xs="6" sm="3">
                            <div class="gp-stat-card text-center gp-animate-fade-in-up gp-animate-stagger-2">
                                <div class="gp-stat-value" style="color: var(--gp-primary-500);">@totalGolfCourses</div>
                                <div class="gp-stat-label">Golf Courses</div>
                            </div>
                        </MudItem>
                        <MudItem xs="6" sm="3">
                            <div class="gp-stat-card text-center gp-animate-fade-in-up gp-animate-stagger-3">
                                <div class="gp-stat-value" style="color: var(--gp-primary-500);">@uniqueCountries</div>
                                <div class="gp-stat-label">Countries</div>
                            </div>
                        </MudItem>
                        <MudItem xs="6" sm="3">
                            <div class="gp-stat-card text-center gp-animate-fade-in-up gp-animate-stagger-4">
                                <div class="gp-stat-value" style="color: var(--gp-accent-600);">FREE</div>
                                <div class="gp-stat-label">Always</div>
                            </div>
                        </MudItem>
                    </MudGrid>
                </MudContainer>
            </section>

            <!-- Features Section -->
            <section class="gp-section gp-section-gradient">
                <MudContainer MaxWidth="MaxWidth.Large">
                    <div class="gp-section-header">
                        <h2 class="gp-section-title">Everything You Need</h2>
                        <p class="gp-section-subtitle">Powerful features designed for golfers of all skill levels</p>
                    </div>
                    <MudGrid Spacing="4">
                        <MudItem xs="12" md="4">
                            <div class="gp-feature-card gp-animate-fade-in-up gp-animate-stagger-1">
                                <div class="gp-feature-icon">📈</div>
                                <h3 class="gp-feature-title">Performance Analytics</h3>
                                <p class="gp-feature-description">
                                    Track your scores over time, analyze trends, and identify areas for improvement with detailed charts and statistics.
                                </p>
                            </div>
                        </MudItem>
                        <MudItem xs="12" md="4">
                            <div class="gp-feature-card gp-animate-fade-in-up gp-animate-stagger-2">
                                <div class="gp-feature-icon">🏌️</div>
                                <h3 class="gp-feature-title">Easy Round Recording</h3>
                                <p class="gp-feature-description">
                                    Record rounds quickly with our intuitive scorecard interface. Track every hole, par, and stroke with ease.
                                </p>
                            </div>
                        </MudItem>
                        <MudItem xs="12" md="4">
                            <div class="gp-feature-card gp-animate-fade-in-up gp-animate-stagger-3">
                                <div class="gp-feature-icon">👥</div>
                                <h3 class="gp-feature-title">Head-to-Head Tracking</h3>
                                <p class="gp-feature-description">
                                    Track your record against playing partners and friends. See who leads the rivalry with detailed stats.
                                </p>
                            </div>
                        </MudItem>
                    </MudGrid>
                </MudContainer>
            </section>

            <!-- Recent Clubs Section -->
            @if (recentGolfClubs is not null && recentGolfClubs.Any())
            {
                <section class="gp-section gp-section-light">
                    <MudContainer MaxWidth="MaxWidth.Large">
                        <div class="gp-section-header">
                            <h2 class="gp-section-title">Explore Our Course Database</h2>
                            <p class="gp-section-subtitle">Browse golf clubs and courses from around the world</p>
                        </div>
                        <MudGrid Spacing="3">
                            @foreach (var club in recentGolfClubs.Take(4))
                            {
                                <MudItem xs="12" sm="6" md="3">
                                    <MudCard Class="gp-card h-100" Elevation="0">
                                        <MudCardContent>
                                            <MudText Typo="Typo.h6" Class="mb-2">@club.Name</MudText>
                                            <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-2">
                                                📍 @club.City@(!string.IsNullOrWhiteSpace(club.Country) ? $", {club.Country}" : "")
                                            </MudText>
                                            <MudChip T="string" Size="Size.Small" Color="Color.Primary" Variant="Variant.Text">
                                                @(club.GolfCourses?.Count ?? 0) course@(club.GolfCourses?.Count != 1 ? "s" : "")
                                            </MudChip>
                                        </MudCardContent>
                                        <MudCardActions>
                                            <MudButton Size="Size.Small" 
                                                       Color="Color.Primary" 
                                                       Variant="Variant.Text"
                                                       Href="@($"/golfclubs/{club.GolfClubId}")">
                                                View Details
                                            </MudButton>
                                        </MudCardActions>
                                    </MudCard>
                                </MudItem>
                            }
                        </MudGrid>
                        <div class="text-center mt-8">
                            <MudButton Variant="Variant.Outlined" 
                                       Color="Color.Primary" 
                                       Href="/golfclubs"
                                       Size="Size.Large"
                                       StartIcon="@Icons.Material.Filled.Explore">
                                Explore All Clubs
                            </MudButton>
                        </div>
                    </MudContainer>
                </section>
            }

            <!-- CTA Section -->
            <section class="gp-hero" style="padding: var(--gp-space-16) var(--gp-space-6);">
                <div class="gp-hero-content">
                    <h2 class="gp-hero-title" style="font-size: clamp(1.875rem, 4vw, 2.5rem);">
                        Ready to Improve Your Game?
                    </h2>
                    <p class="gp-hero-subtitle" style="margin-bottom: var(--gp-space-8);">
                        Start tracking your rounds today and watch your game transform.
                    </p>
                    <MudButton Href="/Account/Register"
                               Variant="Variant.Filled"
                               Size="Size.Large"
                               Class="gp-hero-btn-primary"
                               StartIcon="@Icons.Material.Filled.GolfCourse">
                        Get Started Free
                    </MudButton>
                </div>
            </section>
        }
    </NotAuthorized>
</AuthorizeView>

<style>
    /* Page-specific loading state */
    .gp-loading-container {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        min-height: 60vh;
    }
</style>

@code {
    private bool isLoading = true;
    private bool isAuthenticated = false;
    private int _currentPlayerId;

    // Data for authenticated dashboard
    private DashboardStats dashboardStats = new();
    private List<PlayingPartnerSummary>? partnerSummary;
    private List<ChartSeries> _performanceSeries = new();
    private string[] _performanceXAxisLabels = Array.Empty<string>();
    private List<Round>? recentRounds;

    // Data for public landing page
    private int totalGolfClubs = 0;
    private int totalGolfCourses = 0;
    private int uniqueCountries = 0;
    private List<GolfClub>? recentGolfClubs;

    // Chart configuration
    private ChartOptions _chartOptions = new()
    {
        YAxisTicks = 5,
        MaxNumYAxisTicks = 5,
        YAxisLines = true,
        XAxisLines = false,
        LineStrokeWidth = 3
    };

    private AxisChartOptions _axisChartOptions = new()
    {
        MatchBoundsToSize = true
    };

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        isAuthenticated = user.Identity?.IsAuthenticated ?? false;
        var currentUserId = user.FindFirstValue(ClaimTypes.NameIdentifier);

        if (isAuthenticated && currentUserId is not null)
        {
            // Load authenticated user dashboard data
            var player = await PlayerService.GetPlayerByApplicationUserIdAsync(currentUserId);
            if (player is not null)
            {
                _currentPlayerId = player.PlayerId;
                var isAdmin = user.IsInRole("Admin");

                // Load data for all cards in parallel for efficiency
                var dashboardStatsTask = ReportService.GetDashboardStatsAsync(currentUserId);
                var partnerTask = ReportService.GetPlayingPartnerSummaryAsync(currentUserId, 5);
                var performanceTask = ReportService.GetPlayerPerformanceSummaryAsync(currentUserId, 7);
                var recentRoundsTask = RoundService.GetRecentRoundsAsync(currentUserId, isAdmin, 5);

                await Task.WhenAll(dashboardStatsTask, partnerTask, performanceTask, recentRoundsTask);

                dashboardStats = dashboardStatsTask.Result;
                partnerSummary = partnerTask.Result;
                PreparePerformanceChart(performanceTask.Result);
                recentRounds = recentRoundsTask.Result;
            }
        }
        else
        {
            // Load public landing page data
            await LoadPublicLandingPageData();
        }
        
        isLoading = false;
    }

    private async Task LoadPublicLandingPageData()
    {
        try
        {
            var allClubs = await GolfClubService.GetAllGolfClubsAsync();
            var allCourses = await GolfCourseService.GetAllGolfCoursesAsync();

            totalGolfClubs = allClubs.Count;
            totalGolfCourses = allCourses.Count;
            uniqueCountries = allClubs
                .Where(c => !string.IsNullOrWhiteSpace(c.Country))
                .Select(c => c.Country)
                .Distinct()
                .Count();

            recentGolfClubs = allClubs
                .OrderBy(c => c.Name)
                .Take(6)
                .ToList();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading public landing page data: {ex.Message}");
            totalGolfClubs = 0;
            totalGolfCourses = 0;
            uniqueCountries = 0;
            recentGolfClubs = new List<GolfClub>();
        }
    }

    private void PreparePerformanceChart(List<PlayerPerformanceDataPoint> data)
    {
        if (data is null || !data.Any()) return;

        _performanceSeries = new List<ChartSeries>
        {
            new ChartSeries { Name = "Score vs Par", Data = data.Select(d => (double)d.ScoreVsPar).ToArray() }
        };
        _performanceXAxisLabels = data.Select(d => d.Date.ToString("MMM dd")).ToArray();
    }
}
