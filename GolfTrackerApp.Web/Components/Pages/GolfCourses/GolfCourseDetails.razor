@page "/golfcourses/{CourseId:int}/details"
@rendermode InteractiveServer

@inject IGolfCourseService GolfCourseService
@inject IHoleService HoleService
@inject NavigationManager NavigationManager
@inject ISnackbar Snackbar
@inject ILogger<GolfCourseDetails> Logger
@inject IDialogService DialogService
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject IReportService ReportService
@inject IRoundService RoundService
@inject IPlayerService PlayerService
@inject IAiInsightService AiInsightService
@inject IConfiguration Configuration
@inject ITeeSetService TeeSetService

@using GolfTrackerApp.Web.Models
@using GolfTrackerApp.Web.Services
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using GolfTrackerApp.Web.Components.Shared
@using MudBlazor
@using System.Security.Claims

<PageTitle>@(course?.Name ?? "Course Details")</PageTitle>

@if (isLoading)
{
    <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
}
else if (course is null)
{
    <MudAlert Severity="Severity.Error">Golf course not found.</MudAlert>
}
else
{
    <MudBreadcrumbs Items="_breadcrumbs" Class="mb-4"></MudBreadcrumbs>

    @* ── Dark Header Banner ── *@
    <div class="course-detail-header">
        <div class="course-header-top">
            <div>
                <h2 class="course-name">@course.Name</h2>
                <div class="course-club">@(course.GolfClub?.Name ?? "Golf Club")</div>
            </div>
            <AuthorizeView Roles="Admin">
                <Authorized>
                    <div style="display:flex; gap:6px;">
                        <MudButton Variant="Variant.Outlined"
                                   Style="color:white; border-color:rgba(255,255,255,0.3);"
                                   OnClick="OpenAddHoleDialog"
                                   StartIcon="@Icons.Material.Filled.Add" Size="Size.Small">Hole</MudButton>
                        <MudButton Variant="Variant.Outlined"
                                   Style="color:white; border-color:rgba(255,255,255,0.3);"
                                   OnClick="@(() => NavigationManager.NavigateTo($"/golfcourses/edit/{course.GolfCourseId}"))"
                                   StartIcon="@Icons.Material.Filled.Edit" Size="Size.Small">Edit</MudButton>
                    </div>
                </Authorized>
            </AuthorizeView>
        </div>
        <div class="course-meta">
            <span class="course-meta-item">
                <MudIcon Icon="@Icons.Material.Filled.Flag" Size="Size.Small" />
                Par @course.DefaultPar
            </span>
            <span class="course-meta-item">
                <MudIcon Icon="@Icons.Material.Filled.SportsGolf" Size="Size.Small" />
                @course.NumberOfHoles Holes
            </span>
            @foreach (var ts in _teeSets)
            {
                var totalYards = GetTeeTotalYards(ts.TeeSetId);
                if (totalYards > 0)
                {
                    <span class="course-meta-item">
                        <span style="width:10px;height:10px;border-radius:50%;background:@ts.Colour;border:1px solid rgba(255,255,255,0.4);display:inline-block;"></span>
                        @totalYards yds
                    </span>
                }
            }
            @if (!_teeSets.Any() && holes.Any() && holes.Any(h => h.LengthYards.HasValue && h.LengthYards > 0))
            {
                <span class="course-meta-item">
                    <MudIcon Icon="@Icons.Material.Filled.Straighten" Size="Size.Small" />
                    @(holes.Sum(h => h.LengthYards ?? 0)) Yards
                </span>
            }
            @if (isAuthenticated && _totalRoundCount > 0)
            {
                <span class="course-meta-item">
                    <MudIcon Icon="@Icons.Material.Filled.History" Size="Size.Small" />
                    @_totalRoundCount round@(_totalRoundCount != 1 ? "s" : "") played
                </span>
            }
        </div>
    </div>

    @* ── Quick Stats (authenticated users with data) ── *@
    <AuthorizeView>
        <Authorized>
            @if (isAuthenticated && _totalRoundCount > 0)
            {
                <div class="club-stats-row">
                    <div class="club-stat-card">
                        <div class="stat-icon">🏌️</div>
                        <div class="stat-value">@_totalRoundCount</div>
                        <div class="stat-label">Rounds</div>
                    </div>
                    <div class="club-stat-card accent-green">
                        <div class="stat-icon">⭐</div>
                        <div class="stat-value">@GetBestScore()</div>
                        <div class="stat-label">Best Score</div>
                    </div>
                    <div class="club-stat-card accent-blue">
                        <div class="stat-icon">📊</div>
                        <div class="stat-value">@GetAverageScore()</div>
                        <div class="stat-label">Avg Score</div>
                    </div>
                    <div class="club-stat-card accent-amber">
                        <div class="stat-icon">📅</div>
                        <div class="stat-value">@GetLastPlayedDate()</div>
                        <div class="stat-label">Last Played</div>
                    </div>
                    @if (GetBestVsPar() is not null)
                    {
                        <div class="club-stat-card accent-purple">
                            <div class="stat-icon">🎯</div>
                            <div class="stat-value">@GolfHelpers.FormatVsPar(GetBestVsPar()!.Value)</div>
                            <div class="stat-label">Best vs Par</div>
                        </div>
                    }
                </div>
            }
        </Authorized>
    </AuthorizeView>

    @* ── AI Analysis Panel (authenticated users with data) ── *@
    @if (_aiInsightEnabled && isAuthenticated && _totalRoundCount > 0)
    {
        <MudExpansionPanels Class="mb-3" Elevation="0">
            <MudExpansionPanel @bind-Expanded="_aiPanelExpanded" Dense="true" Style="border: 1px solid #e5e7eb; border-radius: 12px;">
                <TitleContent>
                    <div class="d-flex align-center gap-2">
                        <MudIcon Icon="@Icons.Material.Filled.AutoAwesome" Size="Size.Small" Color="Color.Warning" />
                        <MudText Typo="Typo.subtitle2">AI Analysis</MudText>
                    </div>
                </TitleContent>
                <ChildContent>
                    @if (_aiLoading)
                    {
                        <MudProgressLinear Indeterminate="true" Color="Color.Primary" Class="mb-2" />
                        <MudText Typo="Typo.caption" Color="Color.Secondary">Analysing your performance at @course.Name...</MudText>
                    }
                    else if (_aiInsight?.Success == true)
                    {
                        <MudText Typo="Typo.body2" Style="white-space: pre-line;">@_aiInsight.Content</MudText>
                        @if (!string.IsNullOrEmpty(_aiInsight.StaleMessage))
                        {
                            <MudAlert Severity="Severity.Info" Dense="true" Class="mt-2">@_aiInsight.StaleMessage</MudAlert>
                        }
                        <MudText Typo="Typo.caption" Color="Color.Tertiary" Class="mt-2" Style="font-size: 0.7rem;">Powered by @_aiInsight.ProviderUsed • <MudLink OnClick="LoadCourseInsights" Typo="Typo.caption">Refresh</MudLink></MudText>
                    }
                    else if (_aiInsight != null)
                    {
                        <MudAlert Severity="Severity.Warning" Dense="true">@(_aiInsight.ErrorMessage ?? "Could not load AI insights.")</MudAlert>
                    }
                </ChildContent>
            </MudExpansionPanel>
        </MudExpansionPanels>
    }

    @* ── Hole Table ── *@
    <div class="gp-list-header" style="margin-top:8px;">
        <h4>Hole Details</h4>
    </div>

    <div class="holes-table-wrapper">
        <MudTable Items="@holes.OrderBy(h => h.HoleNumber)" Hover="true" Dense="true" Elevation="0">
            <HeaderContent>
                <MudTh>Hole</MudTh>
                <MudTh>Par</MudTh>
                @foreach (var ts in _teeSets)
                {
                    <MudTh>
                        <div style="display:flex;align-items:center;gap:4px;">
                            <span style="width:10px;height:10px;border-radius:50%;background:@ts.Colour;border:1px solid #ccc;display:inline-block;"></span>
                            @ts.Name
                        </div>
                    </MudTh>
                }
                @if (!_teeSets.Any())
                {
                    <MudTh>Yards</MudTh>
                }
                <MudTh>SI</MudTh>
                @if (isAuthenticated && holeAverages.Any())
                {
                    <MudTh>Your Avg</MudTh>
                }
                <AuthorizeView Roles="Admin">
                    <Authorized Context="authContext">
                        <MudTh Class="golf-text-right">Actions</MudTh>
                    </Authorized>
                </AuthorizeView>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="Hole"><span class="hole-number-cell">@context.HoleNumber</span></MudTd>
                <MudTd DataLabel="Par"><span class="hole-par-cell">@context.Par</span></MudTd>
                @foreach (var ts in _teeSets)
                {
                    var ht = GetHoleTeeForSet(context.HoleId, ts.TeeSetId);
                    <MudTd DataLabel="@ts.Name">@(ht?.LengthYards?.ToString() ?? "-")</MudTd>
                }
                @if (!_teeSets.Any())
                {
                    <MudTd DataLabel="Yards">@(context.LengthYards?.ToString() ?? "-")</MudTd>
                }
                <MudTd DataLabel="SI">@(context.StrokeIndex?.ToString() ?? "-")</MudTd>
                @if (isAuthenticated && holeAverages.Any())
                {
                    var avg = GetHoleAverage(context.HoleId);
                    var diff = avg - context.Par;
                    <MudTd DataLabel="Your Avg">
                        @if (avg > 0)
                        {
                            <span style="font-weight:600;">@avg.ToString("F1")</span>
                            <span class="@GolfHelpers.GetVsParClass((int)Math.Round(diff))" style="font-size:0.75rem; margin-left:4px;">
                                (@GolfHelpers.FormatVsPar((int)Math.Round(diff)))
                            </span>
                        }
                        else
                        {
                            <span style="color:#9ca3af;">-</span>
                        }
                    </MudTd>
                }
                <AuthorizeView Roles="Admin">
                    <Authorized Context="authContext">
                        <MudTd Class="golf-text-right">
                            <MudTooltip Text="Edit Hole">
                                <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small" OnClick="@(() => OpenEditHoleDialog(context))" />
                            </MudTooltip>
                            <MudTooltip Text="Delete Hole">
                                <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Color="Color.Error" OnClick="@(() => PrepareDeleteHole(context))" />
                            </MudTooltip>
                        </MudTd>
                    </Authorized>
                </AuthorizeView>
            </RowTemplate>
        </MudTable>
    </div>

    @* ── Personal Performance Section ── *@
    <AuthorizeView>
        <Authorized>
            @if (currentUserId is not null && (_scoringDistribution is not null || recentRounds.Any()))
            {
                <div class="performance-section">
                    <div class="section-title">
                        <span class="title-icon">📈</span> Your Performance at @course.Name
                    </div>
                
                    <MudGrid Spacing="3" Class="mb-4">
                        @if (_scoringDistribution is not null && _scoringDistribution.TotalHoles > 0)
                        {
                            <MudItem xs="12" md="6">
                                <div class="performance-card">
                                    <div class="card-header">
                                        <MudIcon Icon="@Icons.Material.Filled.PieChart" Size="Size.Small" /> Scoring Distribution
                                    </div>
                                    <div class="card-body">
                                        <div class="golf-chart-wrapper">
                                            <div class="golf-chart-donut">
                                                <MudChart ChartType="ChartType.Pie" 
                                                          InputData="@_pieChartData" 
                                                          InputLabels="@_pieChartLabels" 
                                                          Width="100%" 
                                                          Height="100%"></MudChart>
                                            </div>
                                        </div>
                                        <MudText Typo="Typo.caption" Class="mt-2 text-center" Color="Color.Secondary">Based on @_scoringDistribution.TotalHoles holes</MudText>
                                    </div>
                                </div>
                            </MudItem>
                        }
                        
                        @if (recentRounds.Any())
                        {
                            <MudItem xs="12" md="6">
                                <div class="performance-card">
                                    <div class="card-header">
                                        <MudIcon Icon="@Icons.Material.Filled.History" Size="Size.Small" /> Recent Rounds
                                    </div>
                                    <div class="card-body">
                                        @foreach (var round in recentRounds)
                                        {
                                            var totalScore = GetRoundTotalScore(round);
                                            var vsPar = totalScore - GetRoundPar(round);
                                            <div class="recent-round-item" @onclick="@(() => NavigationManager.NavigateTo($"/rounds/{round.RoundId}"))">
                                                <div>
                                                    <div class="round-date">@round.DatePlayed.ToString("dd MMM yyyy")</div>
                                                    <div class="round-course">@round.GolfCourse?.Name @(round.HolesPlayed < (round.GolfCourse?.NumberOfHoles ?? 18) ? $"({round.HolesPlayed}h)" : "")</div>
                                                </div>
                                                <div class="round-score-mini">
                                                    <span class="score-val">@totalScore</span>
                                                    <span class="score-vs @GolfHelpers.GetVsParClass(vsPar)">@GolfHelpers.FormatVsPar(vsPar)</span>
                                                </div>
                                            </div>
                                        }
                                    </div>
                                </div>
                            </MudItem>
                        }
                    </MudGrid>
                </div>
            }
        </Authorized>
        <NotAuthorized>
            <div class="club-cta-card">
                <div class="cta-title">Track Your Performance</div>
                <div class="cta-text">
                    Join our community to track your rounds at @course.Name and see detailed hole-by-hole analytics.
                </div>
                <div style="display:flex; gap:8px; justify-content:center; flex-wrap:wrap;">
                    <MudButton Variant="Variant.Filled" 
                               Color="Color.Primary" 
                               Href="/Account/Register"
                               StartIcon="@Icons.Material.Filled.TrendingUp">
                        Start Tracking
                    </MudButton>
                    <MudButton Variant="Variant.Outlined" 
                               Color="Color.Primary" 
                               Href="/Account/Login"
                               StartIcon="@Icons.Material.Filled.Login">
                        Sign In
                    </MudButton>
                </div>
            </div>
        </NotAuthorized>
    </AuthorizeView>

    <MudButton Variant="Variant.Text" OnClick="@(() => NavigationManager.NavigateTo($"/golfclubs/{course.GolfClubId}"))" Class="mt-4" StartIcon="@Icons.Material.Filled.ArrowBack">Back to Club</MudButton>
}

@code {
    [Parameter]
    public int CourseId { get; set; }

    private GolfCourse? course;
    private List<Hole> holes = new();
    private bool isLoading = true;
    private List<BreadcrumbItem> _breadcrumbs = new();

    // Tee set data
    private List<TeeSet> _teeSets = new();
    private Dictionary<(int HoleId, int TeeSetId), HoleTee> _holeTeeMap = new();

    // Performance data properties
    private string? currentUserId;
    private int _currentPlayerId;
    private List<ChartSeries> _performanceSeries = new();
    private string[] _performanceXAxisLabels = Array.Empty<string>();
    private List<Round> recentRounds = new();
    private int _totalRoundCount = 0;
    
    // Scoring distribution properties
    private ScoringDistribution? _scoringDistribution;
    private double[] _pieChartData = Array.Empty<double>();
    private string[] _pieChartLabels = Array.Empty<string>();
    
    // Hole-by-hole averages
    private Dictionary<int, double> holeAverages = new();
    
    private bool isAuthenticated = false;

    // AI Insights
    private bool _aiInsightEnabled;
    private bool _aiLoading;
    private bool _aiPanelExpanded
    {
        get => _aiPanelExpandedBacking;
        set
        {
            _aiPanelExpandedBacking = value;
            if (value && _aiInsight == null && !_aiLoading)
                _ = LoadCourseInsights();
        }
    }
    private bool _aiPanelExpandedBacking;
    private AiInsightResult? _aiInsight;

    protected override async Task OnParametersSetAsync()
    {
        isLoading = true;
        
        // Check authentication status
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        isAuthenticated = authState.User.Identity?.IsAuthenticated ?? false;
        _aiInsightEnabled = Configuration.GetValue<bool>("AiInsights:Enabled");
        
        try
        {
            course = await GolfCourseService.GetGolfCourseByIdAsync(CourseId);
            if (course != null)
            {
                holes = await HoleService.GetHolesForCourseAsync(course.GolfCourseId);

                // Ensure all 3 standard tee sets exist (White, Yellow, Red)
                await TeeSetService.EnsureStandardTeeSetsAsync(course.GolfCourseId);

                // Load tee sets for the course
                _teeSets = await TeeSetService.GetTeeSetsForCourseAsync(course.GolfCourseId);
                _holeTeeMap = _teeSets
                    .SelectMany(ts => ts.HoleTees ?? Enumerable.Empty<HoleTee>())
                    .ToDictionary(ht => (ht.HoleId, ht.TeeSetId));

                // Setup breadcrumbs for easy navigation
                _breadcrumbs = new List<BreadcrumbItem>
                {
                    new BreadcrumbItem("Clubs", href: "/golfclubs"),
                    new BreadcrumbItem(course.GolfClub?.Name ?? "Club", href: $"/golfclubs/{course.GolfClubId}"),
                    new BreadcrumbItem(course.Name, href: null, disabled: true)
                };

                // Load personal performance data only if user is authenticated
                if (isAuthenticated)
                {
                    await LoadPersonalPerformanceData();
                }
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error loading course details for CourseId {CourseId}", CourseId);
            Snackbar.Add("Error loading course details.", Severity.Error);
        }
        isLoading = false;
    }

    private async Task LoadCourseInsights()
    {
        if (currentUserId == null) return;
        _aiLoading = true;
        StateHasChanged();
        try
        {
            _aiInsight = await AiInsightService.GetCourseInsightsAsync(currentUserId, CourseId);
        }
        catch
        {
            _aiInsight = new AiInsightResult
            {
                Success = false,
                ErrorMessage = "Could not load AI insights."
            };
        }
        finally
        {
            _aiLoading = false;
            StateHasChanged();
        }
    }

    private async Task LoadPersonalPerformanceData()
    {
        try
        {
            var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
            var user = authState.User;
            currentUserId = user.FindFirstValue(ClaimTypes.NameIdentifier);

            if (currentUserId is not null)
            {
                var player = await PlayerService.GetPlayerByApplicationUserIdAsync(currentUserId);
                if (player is not null)
                {
                    _currentPlayerId = player.PlayerId;

                    // Load performance data and recent rounds in parallel
                    var performanceTask = ReportService.GetPlayerPerformanceForCourseAsync(currentUserId, CourseId, 10);
                    var recentRoundsTask = RoundService.GetRecentRoundsForCourseAsync(currentUserId, CourseId, 10);
                    var scoringDistributionTask = ReportService.GetScoringDistributionAsync(player.PlayerId, CourseId, null, null, null, null);
                    var roundCountTask = RoundService.GetRoundCountForCourseAsync(currentUserId, CourseId);

                    await Task.WhenAll(performanceTask, recentRoundsTask, scoringDistributionTask, roundCountTask);

                    var performanceData = await performanceTask;
                    recentRounds = await recentRoundsTask;
                    _scoringDistribution = await scoringDistributionTask;
                    _totalRoundCount = await roundCountTask;

                    PreparePerformanceChart(performanceData);
                    PreparePieChartData(_scoringDistribution);
                    ComputeHoleAverages();
                }
            }
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Error loading personal performance data for course {CourseId}", CourseId);
            // Don't show error to user, just log it - performance data is optional
        }
    }

    private void PreparePerformanceChart(List<PlayerPerformanceDataPoint> data)
    {
        if (data is null || !data.Any()) 
        {
            _performanceSeries.Clear();
            _performanceXAxisLabels = Array.Empty<string>();
            return;
        }

        _performanceSeries = new List<ChartSeries>
        {
            new ChartSeries { Name = "Score vs Par", Data = data.Select(d => (double)d.ScoreVsPar).ToArray() }
        };
        _performanceXAxisLabels = data.Select(d => d.Date.ToString("dd MMM")).ToArray();
    }

    private void PreparePieChartData(ScoringDistribution? distribution)
    {
        if (distribution is null || distribution.TotalHoles == 0)
        {
            _pieChartData = Array.Empty<double>();
            _pieChartLabels = Array.Empty<string>();
            return;
        }

        var data = new List<double>();
        var labels = new List<string>();

        // Add ALL categories, including those with 0 counts for completeness
        if (distribution.EagleCount > 0)
        {
            data.Add(distribution.EagleCount);
            labels.Add($"Eagle ({distribution.EagleCount})");
        }
        
        if (distribution.BirdieCount > 0)
        {
            data.Add(distribution.BirdieCount);
            labels.Add($"Birdie ({distribution.BirdieCount})");
        }
        
        // Always include Par, Bogey as they're the most common
        data.Add(distribution.ParCount);
        labels.Add($"Par ({distribution.ParCount})");
        
        data.Add(distribution.BogeyCount);
        labels.Add($"Bogey ({distribution.BogeyCount})");
        
        if (distribution.DoubleBogeyCount > 0)
        {
            data.Add(distribution.DoubleBogeyCount);
            labels.Add($"Double Bogey ({distribution.DoubleBogeyCount})");
        }
        
        if (distribution.TripleBogeyOrWorseCount > 0)
        {
            data.Add(distribution.TripleBogeyOrWorseCount);
            labels.Add($"Triple+ ({distribution.TripleBogeyOrWorseCount})");
        }

        // Use InputData format for pie chart
        _pieChartData = data.ToArray();
        _pieChartLabels = labels.ToArray();
    }

    private void ComputeHoleAverages()
    {
        holeAverages.Clear();
        if (!recentRounds.Any()) return;

        var allScores = recentRounds
            .Where(r => r.Scores != null)
            .SelectMany(r => r.Scores!.Where(s => s.PlayerId == _currentPlayerId))
            .ToList();

        holeAverages = allScores
            .GroupBy(s => s.HoleId)
            .ToDictionary(g => g.Key, g => g.Average(s => (double)s.Strokes));
    }

    private double GetHoleAverage(int holeId)
    {
        return holeAverages.TryGetValue(holeId, out var avg) ? avg : 0;
    }

    private int GetRoundTotalScore(Round round)
    {
        if (round.Scores == null || !round.Scores.Any()) return 0;
        return round.Scores.Where(s => s.PlayerId == _currentPlayerId).Sum(s => s.Strokes);
    }

    private string GetBestScore()
    {
        if (!recentRounds.Any()) return "-";
        var scores = recentRounds.Select(GetRoundTotalScore).Where(s => s > 0);
        return scores.Any() ? scores.Min().ToString() : "-";
    }

    private string GetAverageScore()
    {
        if (!recentRounds.Any()) return "-";
        var scores = recentRounds.Select(GetRoundTotalScore).Where(s => s > 0).ToList();
        return scores.Any() ? scores.Average().ToString("F1") : "-";
    }

    private string GetLastPlayedDate()
    {
        if (!recentRounds.Any()) return "-";
        return recentRounds.Max(r => r.DatePlayed).ToString("dd MMM");
    }

    private int GetRoundPar(Round round)
    {
        if (round.HolesPlayed >= (course?.NumberOfHoles ?? 18))
            return course?.DefaultPar ?? 72;

        // Use the page's holes data for accurate per-hole pars
        if (holes.Any())
        {
            var actualPar = holes
                .Where(h => h.HoleNumber >= round.StartingHole && h.HoleNumber < round.StartingHole + round.HolesPlayed)
                .Sum(h => h.Par);
            if (actualPar > 0) return actualPar;
        }

        return (int)Math.Round((double)(course?.DefaultPar ?? 72) * round.HolesPlayed / (course?.NumberOfHoles ?? 18));
    }

    private int? GetBestVsPar()
    {
        if (!recentRounds.Any() || course == null) return null;
        var vsParValues = recentRounds
            .Select(r => { var s = GetRoundTotalScore(r); return s > 0 ? s - GetRoundPar(r) : (int?)null; })
            .Where(v => v.HasValue)
            .Select(v => v!.Value)
            .ToList();
        return vsParValues.Any() ? vsParValues.Min() : null;
    }

    private async Task OpenAddHoleDialog()
    {
        if (course is null || !isAuthenticated) return;
        var newHole = new Hole { GolfCourseId = course.GolfCourseId };
        var parameters = new DialogParameters<AddEditHoleDialog>
        {
            { x => x.HoleModel, newHole },
            { x => x.Title, "Add New Hole" }
        };
        var dialog = await DialogService.ShowAsync<AddEditHoleDialog>("Add Hole", parameters);
        var result = await dialog.Result;
        if (result is not null && !result.Canceled)
        {
            await OnParametersSetAsync(); // Refresh the list
        }
    }

    private async Task OpenEditHoleDialog(Hole holeToEdit)
    {
        if (!isAuthenticated) return;
        var parameters = new DialogParameters<AddEditHoleDialog>
        {
            { x => x.HoleModel, holeToEdit },
            { x => x.Title, $"Edit Hole {holeToEdit.HoleNumber}" }
        };
        var dialog = await DialogService.ShowAsync<AddEditHoleDialog>("Edit Hole", parameters);
        var result = await dialog.Result;
        if (result is not null && !result.Canceled)
        {
            await OnParametersSetAsync(); // Refresh the list
        }
    }

    private async Task PrepareDeleteHole(Hole holeToDelete)
    {
        if (!isAuthenticated) return;
        
        var parameters = new DialogParameters<ConfirmDialog>
        {
            { nameof(ConfirmDialog.ContentText), $"Are you sure you want to delete Hole {holeToDelete.HoleNumber}?" },
            { nameof(ConfirmDialog.ButtonText), "Delete" },
            { nameof(ConfirmDialog.Color), Color.Error }
        };
        var dialog = await DialogService.ShowAsync<ConfirmDialog>("Confirm Delete", parameters);
        var result = await dialog.Result;

        if (result is not null && !result.Canceled && result.Data is true)
        {
            try
            {
                bool deleted = await HoleService.DeleteHoleAsync(holeToDelete.HoleId);
                if (deleted)
                {
                    Snackbar.Add("Hole deleted successfully.", Severity.Success);
                    await OnParametersSetAsync(); // Refresh the list of holes
                }
                else
                {
                    Snackbar.Add("Failed to delete hole.", Severity.Warning);
                }
            }
            catch (Exception ex)
            {
                Snackbar.Add($"Error deleting hole: {ex.Message}", Severity.Error);
            }
        }
    }

    // ── Tee Set Helpers ──

    private HoleTee? GetHoleTeeForSet(int holeId, int teeSetId)
    {
        _holeTeeMap.TryGetValue((holeId, teeSetId), out var ht);
        return ht;
    }

    private int GetTeeTotalYards(int teeSetId)
    {
        return _holeTeeMap
            .Where(kvp => kvp.Key.TeeSetId == teeSetId)
            .Sum(kvp => kvp.Value.LengthYards ?? 0);
    }
}